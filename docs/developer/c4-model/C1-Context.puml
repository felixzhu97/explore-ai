@startuml C1-Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title 系统上下文图 (C1) - AI Chat & Agent Platform

' ============================================================
' PEOPLE
' ============================================================
Person(user, "用户", "对话、RAG、Agent 流水线、图像生成/TTS、可选 Image Analysis/MCP/Eval/ASR")
Person(admin, "管理员/开发者", "质量评估、文本分析、API 集成、功能开关配置")

' ============================================================
' AI Chat & Agent Platform
' ============================================================
System_Boundary(ai_platform, "AI Chat & Agent Platform") {
    System(frontend, "Web Frontend", "Angular 22 + TypeScript", "Vercel 静态部署 (prod) / ng serve :4200 (dev)\n路由: /chat /generate /rag + flag: /agents /vision /mcp /eval /asr")
    System(backend, "AI Platform Backend", "Spring Boot 4.1 / Java 25 / Spring AI 2.0", "Railway Docker :8080 (prod) / Gradle :9000 (dev)\nClean Architecture · 11 子域")
}

' ============================================================
' PLATFORM SERVICES
' ============================================================
System_Ext(launchdarkly, "LaunchDarkly", "功能开关 (module-agents/vision/asr/mcp/eval)\n前端 Client SDK + 后端 Server SDK")
System_Ext(datadog, "Datadog (us5)", "RUM (浏览器) + APM (经 Railway Agent)\n构建时注入 RUM 凭证，OSS 仓库不含密钥")

' ============================================================
' CLOUD AI SERVICES (prod + dev)
' ============================================================
System_Ext(deepseek_api, "DeepSeek API", "LLM 对话 (deepseek-v4-flash)")
System_Ext(openai_api, "OpenAI API", "DALL-E 图像生成 + TTS 语音合成")
System_Ext(serper_api, "Serper.dev API", "Web 搜索，实时信息检索")

' ============================================================
' DATA & LOCAL-ONLY SERVICES (dev / optional)
' ============================================================
System_Ext(h2_db, "H2 Embedded", "嵌入式数据库 + 向量存储 (默认，prod Railway volume)")
System_Ext(ollama, "Ollama [local]", "本地 Embedding (mxbai-embed-large) + 多模态 RAG Vision (qwen3.5)，:11434\nprod cloud-minimal 默认关闭")
System_Ext(tesseract, "Tesseract OCR [local]", "本地 OCR (eng/chi_sim)，Tess4J JNA\nprod 默认关闭 (module-vision=false)")
System_Ext(whisper_cpp, "whisper.cpp [local]", "本地流式 ASR，:8178\nprod 默认关闭 (module-audio-asr=false)")
System_Ext(onnx_vision, "Image Analysis ONNX [local]", "BLIP Caption + YOLOv8 Detect，models/*.onnx\nprod 默认关闭 (module-vision=false)")

' ============================================================
' RELATIONSHIPS
' ============================================================
Rel(user, frontend, "使用 Web UI", "HTTPS")
Rel(admin, launchdarkly, "配置功能开关", "HTTPS")
Rel(admin, backend, "评估 / 分析 API", "HTTPS")
Rel(frontend, backend, "REST / SSE / WebSocket", "HTTPS (prod Railway / dev :9000)")

Rel(frontend, launchdarkly, "读取模块开关", "HTTPS")
Rel(frontend, datadog, "RUM 遥测", "HTTPS us5")
Rel(backend, launchdarkly, "读取模块开关 + 启动引导", "HTTPS")
Rel(backend, datadog, "APM（经 Railway Agent）", "Private Network → HTTPS us5")

Rel(backend, deepseek_api, "LLM 调用", "HTTPS")
Rel(backend, openai_api, "图像生成 + TTS", "HTTPS")
Rel(backend, serper_api, "Web 搜索", "HTTPS")
Rel(backend, h2_db, "会话元数据 + ChatMemory + 向量", "JDBC 内嵌")

Rel_Back(backend, ollama, "Embedding + 多模态 RAG [dev]", "HTTP :11434")
Rel_Back(backend, tesseract, "OCR [dev]", "JNA")
Rel_Back(backend, whisper_cpp, "流式 ASR [dev]", "HTTP/WS :8178")
Rel_Back(backend, onnx_vision, "Caption / Detect [dev]", "文件 I/O")

SHOW_LEGEND()
@enduml
