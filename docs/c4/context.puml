@startuml C4-Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title 系统上下文图 (C1) - AI Chat Application

' 人员定义
Person(user, "用户", "使用 AI 聊天功能进行对话")

' AI Chat Application 系统边界
System_Boundary(ai_chat_app, "AI Chat Application") {
    System(frontend, "Web 前端", "Angular 20+ + TypeScript + SCSS", "用户界面和交互")
    System(backend, "AI 聊天后端", "Java 25 + Spring Boot 3.5 + Spring AI 1.1.7", "聊天会话管理、AI 对话处理")
}

' 外部服务
System_Ext(deepseek_api, "DeepSeek API", "DeepSeek 大语言模型服务")

' 用户关系
Rel(user, frontend, "发送消息/接收回复", "HTTPS")
Rel(frontend, backend, "发送请求/流式响应", "HTTP/SSE")

' 后端与 LLM 关系
Rel(backend, deepseek_api, "LLM 调用", "HTTPS")

SHOW_LEGEND()
@enduml
