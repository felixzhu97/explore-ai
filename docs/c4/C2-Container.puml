@startuml C2-Container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title 容器图 (C2) - AI Platform Backend (10 子域)

' ============================================================
' PEOPLE
' ============================================================
Person(user, "用户", "对话、文档、工具、视觉、语音")
Person(admin, "管理员/开发者", "评估、文本分析、API 集成")

' ============================================================
' FRONTEND
' ============================================================
Container(angular_app, "Web Frontend", "Angular 22 + TypeScript", "路由 /chat /rag /vision，SSE 流式对话")

' ============================================================
' BACKEND
' ============================================================
Container(backend, "AI Platform Backend", "Spring Boot 4.0 / Java 25 / Spring AI 2.0", "10 子域，端口 9000")

' ============================================================
' DOMAIN 1: CHAT
' ============================================================
Container_Boundary(chat_domain, "Chat Domain") {
    Container(chat_controller, "ChatController", "@RestController", "/api/chat, /api/sessions")
    Container(chat_facade, "ChatFacade", "Application Service", "聊天门面")
    Container(chat_usecase, "SpringAiChatUseCase", "Use Case", "Spring AI 对话实现")
    Container(chat_session, "ChatSession", "Aggregate Root", "聊天会话聚合根")
    Container(in_mem_sess_repo, "InMemoryChatSessionRepository", "@Repository", "内存会话存储")
}

' ============================================================
' DOMAIN 2: RAG (+ ETL)
' ============================================================
Container_Boundary(rag_domain, "RAG Domain") {
    Container(rag_controller, "RagController", "@RestController", "/api/rag/*")
    Container(rag_app_svc, "RagApplicationService", "Application Service", "RAG 门面")
    Container(doc_upload_svc, "DocumentUploadService", "Use Case", "文档上传/列表/删除 (ETL 编排)")
    Container(doc_search_svc, "DocumentSearchService", "Use Case", "向量检索")
    Container(rag_chat_svc, "RagChatUseCase", "Use Case", "RAG 聊天")
    Container(vision_chat_svc, "VisionChatUseCase", "Use Case", "多模态 RAG (Ollama qwen3.5)")
    Container(reader_port, "DocumentReader", "Port", "ETL 读取")
    Container(transformer_port, "DocumentTransformer", "Port", "ETL 转换")
    Container(writer_port, "DocumentWriter", "Port", "ETL 写入")
    Container(etl_reader, "PdfAndTextDocumentReader", "@Component", "PDF/TXT 读取")
    Container(etl_transformer, "ChunkingDocumentTransformer", "@Component", "分块转换")
    Container(etl_writer, "EmbeddingDocumentWriter", "@Component", "Embedding 写入")
    Container(h2_vector, "H2VectorAdapter", "@Component", "H2 向量检索 (默认)")
    Container(ollama_emb, "OllamaEmbeddingAdapter", "@Component", "mxbai-embed-large (1024)")
}

' ============================================================
' DOMAIN 3: TOOLS (DDD)
' ============================================================
Container_Boundary(tool_domain, "Tools Domain") {
    Container(tool_controller, "ToolsController", "@RestController", "/api/tools/*")
    Container(tool_facade, "ToolsFacade", "Application Service", "工具门面")
    Container(weather_report, "WeatherReport", "Domain Model", "天气报告充血模型")
    Container(weather_query, "WeatherQuery", "Value Object", "天气查询 VO")
    Container(rag_search_tool, "RagSearchTool", "*Tool", "RAG 搜索工具")
    Container(weather_tool, "WeatherTools", "*Tool", "天气查询工具")
    Container(web_search_tool, "SerperWebSearchAdapter", "*Tool", "Web 搜索 (Serper.dev)")
}

' ============================================================
' DOMAIN 4: ANALYSIS
' ============================================================
Container_Boundary(analysis_domain, "Analysis Domain") {
    Container(analysis_controller, "AnalysisController", "@RestController", "/api/chat/analyze")
    Container(analysis_facade, "AnalysisFacade", "Application Service", "结构化文本分析")
    Container(text_analysis, "TextAnalysis", "Domain Model", "情感/结构化分析结果")
}

' ============================================================
' DOMAIN 5: EVAL
' ============================================================
Container_Boundary(eval_domain, "Evaluation Domain") {
    Container(eval_controller, "EvalController", "@RestController", "/api/eval/chat")
    Container(eval_svc, "ChatQualityEvaluator", "Domain Service", "LLM-as-a-Judge 质量评估")
    Container(eval_result, "ChatEvaluationResult", "Value Object", "评估结果")
}

' ============================================================
' DOMAIN 6: IMAGE
' ============================================================
Container_Boundary(image_domain, "Image Domain") {
    Container(image_controller, "ImageController", "@RestController", "/api/image/*")
    Container(image_facade, "ImageFacade", "Application Service", "图像生成门面")
    Container(image_repo, "SpringAiImageGenerationRepository", "@Component", "DALL-E 适配器")
}

' ============================================================
' DOMAIN 7: AUDIO (TTS + ASR)
' ============================================================
Container_Boundary(audio_domain, "Audio Domain") {
    Container(audio_controller, "AudioController", "@RestController", "TTS HTTP + ASR WebSocket")
    Container(audio_facade, "AudioFacade", "Application Service", "TTS 门面")
    Container(asr_usecase, "StreamingTranscriptionUseCase", "Use Case", "流式转录")
    Container(asr_ws_handler, "AudioTranscriptionWebSocketHandler", "@Component", "ASR WebSocket")
    Container(asr_adapter, "WhisperCppTranscriptionAdapter", "@Component", "whisper.cpp 适配器")
    Container(tts_repo, "SpringAiTextToSpeechRepository", "@Component", "OpenAI TTS 适配器")
}

' ============================================================
' DOMAIN 8: MCP SERVER
' ============================================================
Container_Boundary(mcp_server_domain, "MCP Server Domain") {
    Container(mcp_controller, "McpController", "@RestController", "/api/mcp/*")
    Container(mcp_server_svc, "AiMcpServerService", "Infrastructure", "MCP Server 实现")
}

' ============================================================
' DOMAIN 9: MCP CLIENT
' ============================================================
Container_Boundary(mcp_client_domain, "MCP Client Domain") {
    Container(mcp_client_controller, "McpClientController", "@RestController", "/api/mcp-client/*")
    Container(mcp_facade, "McpFacade", "Application Service", "MCP Client 门面")
    Container(mcp_client_repo, "SpringAiMcpClientRepository", "@Component", "MCP Client 适配器")
}

' ============================================================
' CROSS-CUTTING
' ============================================================
Container_Boundary(crosscut, "Cross-Cutting") {
    Container(ex_handler, "GlobalExceptionHandler", "@RestControllerAdvice", "统一异常处理")
    Container(h2_datasource, "H2 DataSource", "Embedded DB", "默认 jdbc:h2:file:./data/explore-ai")
}

' ============================================================
' EXTERNAL SYSTEMS
' ============================================================
ContainerDb(h2_db, "H2 Embedded", "H2 + Liquibase", "文档元数据 + 向量 (默认)", "内嵌")
ContainerDb(postgresql, "PostgreSQL + pgvector", "PostgreSQL 17", "可选生产向量库", "5432")
Container_Ext(deepseek_api, "DeepSeek API", "REST API", "LLM 对话", "HTTPS")
Container_Ext(ollama_svc, "Ollama", "REST API", "mxbai-embed-large + qwen3.5 Vision", "11434")
Container_Ext(whisper_cpp_svc, "whisper.cpp", "REST/WebSocket", "流式 ASR", "8178")
Container_Ext(dalle_api, "DALL-E API", "REST API", "图像生成", "HTTPS")
Container_Ext(tts_ext_api, "TTS Service", "REST API", "语音合成", "HTTPS")
Container_Ext(serper_api, "Serper.dev API", "REST API", "Web 搜索", "HTTPS")

' ============================================================
' RELATIONSHIPS
' ============================================================
Rel(user, angular_app, "使用 Web UI", "HTTP/SSE/WebSocket")
Rel(admin, eval_controller, "质量评估", "HTTP")
Rel(admin, analysis_controller, "文本分析", "HTTP")

Rel(angular_app, chat_controller, "聊天", "HTTP/SSE")
Rel(angular_app, rag_controller, "RAG", "HTTP/SSE")
Rel(angular_app, tool_controller, "工具", "HTTP")
Rel(angular_app, image_controller, "图像", "HTTP")
Rel(angular_app, audio_controller, "TTS + ASR", "HTTP/WebSocket")
Rel(angular_app, mcp_controller, "MCP Server", "HTTP")
Rel(angular_app, mcp_client_controller, "MCP Client", "HTTP")

Rel(chat_controller, chat_facade, "调用")
Rel(chat_facade, chat_usecase, "委托")
Rel(chat_usecase, in_mem_sess_repo, "会话存储")
Rel(chat_usecase, deepseek_api, "LLM", "HTTPS")

Rel(rag_controller, rag_app_svc, "调用")
Rel(rag_app_svc, doc_upload_svc, "上传/删除")
Rel(rag_app_svc, doc_search_svc, "检索")
Rel(rag_app_svc, rag_chat_svc, "RAG 聊天")
Rel(rag_controller, vision_chat_svc, "视觉聊天")
Rel(doc_upload_svc, reader_port, "ETL 读取")
Rel(doc_upload_svc, transformer_port, "ETL 转换")
Rel(doc_upload_svc, writer_port, "ETL 写入")
Rel(reader_port, etl_reader, "实现")
Rel(transformer_port, etl_transformer, "实现")
Rel(writer_port, etl_writer, "实现")
Rel(doc_search_svc, h2_vector, "向量检索")
Rel(etl_writer, ollama_emb, "Embedding")
Rel(h2_vector, h2_db, "向量存储", "JDBC")
Rel(ollama_emb, ollama_svc, "Embedding", "HTTP")
Rel(vision_chat_svc, ollama_svc, "Vision", "HTTP")

Rel(tool_controller, tool_facade, "调用")
Rel(tool_facade, weather_tool, "天气")
Rel(tool_facade, rag_search_tool, "RAG 搜索")
Rel(tool_facade, web_search_tool, "Web 搜索")
Rel(weather_tool, weather_report, "领域模型")
Rel(rag_search_tool, rag_app_svc, "RAG 检索")
Rel(web_search_tool, serper_api, "搜索", "HTTPS")

Rel(analysis_controller, analysis_facade, "调用")
Rel(analysis_facade, deepseek_api, "结构化输出", "HTTPS")

Rel(eval_controller, eval_svc, "调用")
Rel(eval_svc, deepseek_api, "LLM 评估", "HTTPS")

Rel(image_controller, image_facade, "调用")
Rel(image_facade, image_repo, "生成")
Rel(image_repo, dalle_api, "DALL-E", "HTTPS")

Rel(audio_controller, audio_facade, "TTS")
Rel(audio_controller, asr_ws_handler, "ASR WebSocket")
Rel(audio_facade, tts_repo, "合成")
Rel(asr_ws_handler, asr_usecase, "流式转录")
Rel(asr_usecase, asr_adapter, "调用")
Rel(asr_adapter, whisper_cpp_svc, "转录", "HTTP :8178")
Rel(tts_repo, tts_ext_api, "TTS", "HTTPS")

Rel(mcp_controller, mcp_server_svc, "调用")
Rel(mcp_client_controller, mcp_facade, "调用")
Rel(mcp_facade, mcp_client_repo, "MCP 连接")

SHOW_LEGEND()
@enduml
