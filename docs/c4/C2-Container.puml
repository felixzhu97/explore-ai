@startuml C2-Container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title 容器图 (C2) - AI Platform Backend (Chat + RAG + Tool Calling + Image + TTS + MCP)

' ============================================================
' PEOPLE - 人员
' ============================================================
Person(user, "用户", "与 AI 助手对话，上传和管理文档，调用工具")

' ============================================================
' FRONTEND - 前端容器
' ============================================================
Container(angular_app, "Web Frontend", "Angular 22 + TypeScript", "Web 用户界面，支持 SSE 实时对话")

' ============================================================
' AI PLATFORM BACKEND - 后端容器 (Clean Architecture)
' ============================================================
Container(backend, "AI Platform Backend", "Spring Boot 4.0 / Java 25 / Spring AI 2.0", "会话管理·RAG·Tool Calling·图像生成·TTS·MCP，端口 9000")

' ============================================================
' DOMAIN 1: CHAT DOMAIN
' ============================================================
Container_Boundary(chat_domain, "Chat Domain") {
    Container(chat_controller, "AiController", "@RestController", "聊天 HTTP/SSE 请求")
    Container(chat_dto, "Chat DTOs", "Java Records", "请求/响应/会话信息 DTO")
    Container(ai_chat_svc, "AiChatService", "Domain Service", "AI 对话核心服务")
    Container(chat_session, "ChatSession", "Aggregate Root", "聊天会话聚合根")
    Container(chat_message, "ChatMessage", "Entity", "聊天消息实体")
    Container(in_mem_sess_repo, "InMemoryChatSessionRepository", "@Repository", "内存会话存储")
}

' ============================================================
' DOMAIN 2: RAG DOMAIN
' ============================================================
Container_Boundary(rag_domain, "RAG Domain") {
    Container(rag_controller, "RagController", "@RestController", "RAG HTTP/SSE 请求")
    Container(rag_dto, "RAG DTOs", "Java Records", "RAG 聊天 / 文档上传请求 DTO")
    Container(rag_app_svc, "RagService", "Domain Service", "RAG 服务")
    Container(rag_chat_svc, "RagChatUseCase", "Use Case", "RAG 聊天用例")
    Container(vision_chat_svc, "VisionChatUseCase", "Use Case", "多模态 RAG 聊天用例 (Ollama qwen3.5)")
    Container(embedding_port, "EmbeddingAdapter", "Interface (Port)", "文本嵌入能力抽象")
    Container(vector_search_port, "VectorSearchPort", "Interface (Port)", "向量检索抽象")
    Container(doc_repo_port, "DocumentRepository", "Interface (Port)", "文档仓储抽象")
    Container(document, "Document", "Entity", "文档实体")
    Container(doc_chunk, "DocumentChunk", "Entity", "文档分块实体")
    Container(ollama_emb_adapter, "OllamaEmbeddingAdapter", "@Component", "Ollama Embedding 适配器 (nomic-embed-text)")
    Container(mock_emb_adapter, "MockEmbeddingAdapter", "@Component", "Mock Embedding 适配器")
    Container(pgvector_adapter, "PgVectorAdapter", "@Component", "PostgreSQL/pgvector 向量检索")
    Container(jpa_doc_repo, "JpaDocumentRepository", "@Repository", "JPA 文档仓储实现")
    Container(spring_data_doc_repo, "SpringDataDocumentRepository", "Spring Data JPA", "文档数据访问")
    Container(spring_data_chunk_repo, "SpringDataChunkRepository", "Spring Data JPA", "分块数据访问")
    Container(pdf_extractor, "PdfTextExtractor", "@Component", "PDF 文本提取")
}

' ============================================================
' DOMAIN 3: TOOL CALLING DOMAIN
' ============================================================
Container_Boundary(tool_domain, "Tool Calling Domain") {
    Container(tool_controller, "ToolsController", "@RestController", "工具调用 HTTP 请求")
    Container(tool_facade, "ToolsFacade", "Facade", "工具调用门面，协调各工具")
    Container(tool_dto, "Tool DTOs", "Java Records", "工具列表/调用请求 DTO")
    Container(rag_search_tool, "RagSearchTool", "*Tool", "RAG 搜索工具")
    Container(weather_tool, "WeatherTools", "*Tool", "天气查询工具")
    Container(web_search_tool, "SerperWebSearchAdapter", "*Tool", "Web 搜索工具 (Serper.dev)")
}

' ============================================================
' DOMAIN 4: IMAGE GENERATION DOMAIN
' ============================================================
Container_Boundary(image_domain, "Image Generation Domain") {
    Container(image_controller, "ImageController", "@RestController", "图像生成 HTTP 请求")
    Container(image_dto, "Image DTOs", "Java Records", "图像生成请求/响应 DTO")
    Container(image_svc, "ImageGenerationService", "Domain Service", "图像生成核心服务")
    Container(image_adapter, "OpenAiImageAdapter", "@Component", "DALL-E 图像生成适配器")
}

' ============================================================
' DOMAIN 5: AUDIO/TTS DOMAIN
' ============================================================
Container_Boundary(tts_domain, "Audio/TTS Domain") {
    Container(audio_controller, "AudioController", "@RestController", "TTS HTTP 请求")
    Container(tts_dto, "TTS DTOs", "Java Records", "TTS 请求/响应 DTO")
    Container(tts_svc, "TextToSpeechService", "Domain Service", "语音合成核心服务")
    Container(tts_adapter, "OpenAiTtsAdapter", "@Component", "OpenAI TTS 适配器")
}

' ============================================================
' DOMAIN 6: MCP SERVER DOMAIN
' ============================================================
Container_Boundary(mcp_server_domain, "MCP Server Domain") {
    Container(mcp_controller, "McpController", "@RestController", "MCP Server HTTP 请求")
    Container(mcp_server_dto, "MCP DTOs", "Java Records", "MCP 工具调用请求/响应 DTO")
    Container(mcp_server_svc, "McpServerService", "Domain Service", "MCP Server 核心服务")
}

' ============================================================
' DOMAIN 7: MCP CLIENT DOMAIN
' ============================================================
Container_Boundary(mcp_client_domain, "MCP Client Domain") {
    Container(mcp_client_controller, "McpClientController", "@RestController", "MCP Client HTTP 请求")
    Container(mcp_client_dto, "MCP Client DTOs", "Java Records", "MCP Client 请求/响应 DTO")
    Container(mcp_client_svc, "AiMcpClientService", "Domain Service", "MCP Client 核心服务")
}

' ============================================================
' CROSS-CUTTING - 跨领域
' ============================================================
Container_Boundary(crosscut_domain, "Cross-Cutting") {
    Container(app_config, "ApplicationConfig", "@Configuration", "应用总配置")
    Container(postgres_config, "PostgresConfig", "@Configuration", "PostgreSQL 配置")
    Container(ollama_config, "OllamaConfig", "@Configuration", "Ollama 配置")
    Container(rag_props, "RagProperties", "@ConfigurationProperties", "RAG 配置属性")
    Container(chat_config, "ChatConfig", "@Configuration", "聊天配置")
    Container(cors_config, "WebCorsConfig", "@Configuration", "跨域配置")
    Container(ex_handler, "GlobalExceptionHandler", "@RestControllerAdvice", "统一异常处理")
}

' ============================================================
' EXTERNAL SYSTEMS - 外部系统
' ============================================================
ContainerDb(postgresql, "PostgreSQL + pgvector", "PostgreSQL 17", "文档元数据 + 向量嵌入", "5432")
Container_Ext(deepseek_api, "DeepSeek API", "REST API", "LLM 对话 + Text Embedding", "HTTPS")
Container_Ext(ollama_svc, "Ollama", "REST API", "本地 Embedding + Vision 模型 (qwen3.5)", "11434")
Container_Ext(dalle_api, "DALL-E API", "REST API", "图像生成服务", "HTTPS")
Container_Ext(tts_ext_api, "TTS Service", "REST API", "语音合成服务", "HTTPS")
Container_Ext(serper_api, "Serper.dev API", "REST API", "Web 搜索服务", "HTTPS")

' ============================================================
' RELATIONSHIPS - 关系
' ============================================================

' User <-> Frontend
Rel(user, angular_app, "对话 / 文档 / 工具调用", "HTTP/SSE")

' Frontend -> Backend
Rel(angular_app, chat_controller, "聊天请求", "HTTP/SSE :9000")
Rel(angular_app, rag_controller, "RAG 请求", "HTTP/SSE :9000")
Rel(angular_app, tool_controller, "工具调用", "HTTP :9000")
Rel(angular_app, image_controller, "图像生成", "HTTP :9000")
Rel(angular_app, audio_controller, "TTS 请求", "HTTP :9000")
Rel(angular_app, mcp_controller, "MCP Server", "HTTP :9000")
Rel(angular_app, mcp_client_controller, "MCP Client", "HTTP :9000")

' Chat Domain
Rel(chat_controller, ai_chat_svc, "调用")
Rel(ai_chat_svc, chat_session, "操作领域对象")
Rel(chat_session, chat_message, "包含")
Rel(ai_chat_svc, in_mem_sess_repo, "依赖")
Rel(in_mem_sess_repo, deepseek_api, "LLM 调用", "HTTPS")

' RAG Domain
Rel(rag_controller, rag_app_svc, "调用")
Rel(rag_controller, vision_chat_svc, "多模态聊天")
Rel(rag_app_svc, rag_chat_svc, "RAG 聊天")
Rel(rag_app_svc, vision_chat_svc, "视觉聊天")
Rel(rag_app_svc, embedding_port, "依赖")
Rel(rag_app_svc, vector_search_port, "依赖")
Rel(rag_app_svc, doc_repo_port, "依赖")
Rel(rag_app_svc, pdf_extractor, "PDF 处理")
Rel(vision_chat_svc, rag_chat_svc, "复用上下文")
Rel(vision_chat_svc, ollama_svc, "视觉理解 (qwen3.5)", "HTTP :11434")
Rel(embedding_port, ollama_emb_adapter, "实现")
Rel(embedding_port, mock_emb_adapter, "实现")
Rel(vector_search_port, pgvector_adapter, "实现")
Rel(doc_repo_port, jpa_doc_repo, "实现")
Rel(jpa_doc_repo, spring_data_doc_repo, "组合")
Rel(jpa_doc_repo, spring_data_chunk_repo, "组合")
Rel(pgvector_adapter, postgresql, "向量存储/检索", "JDBC :5432")
Rel(jpa_doc_repo, postgresql, "文档持久化", "JDBC :5432")
Rel(ollama_emb_adapter, ollama_svc, "Embedding 生成", "HTTP :11434")
Rel(document, doc_chunk, "包含多个")

' Tool Calling Domain
Rel(tool_controller, tool_facade, "调用")
Rel(tool_facade, rag_search_tool, "RAG 搜索")
Rel(tool_facade, weather_tool, "天气查询")
Rel(tool_facade, web_search_tool, "Web 搜索")
Rel(rag_search_tool, rag_app_svc, "RAG 服务")
Rel(weather_tool, deepseek_api, "天气 API", "HTTPS")
Rel(web_search_tool, serper_api, "Web 搜索", "HTTPS")

' Image Generation Domain
Rel(image_controller, image_svc, "调用")
Rel(image_svc, image_adapter, "依赖")
Rel(image_adapter, dalle_api, "图像生成", "HTTPS")

' Audio/TTS Domain
Rel(audio_controller, tts_svc, "调用")
Rel(tts_svc, tts_adapter, "依赖")
Rel(tts_adapter, tts_ext_api, "语音合成", "HTTPS")

' MCP Server Domain
Rel(mcp_controller, mcp_server_svc, "调用")

' MCP Client Domain
Rel(mcp_client_controller, mcp_client_svc, "调用")

SHOW_LEGEND()
@enduml
