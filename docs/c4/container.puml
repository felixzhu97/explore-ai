@startuml C4-Container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title 容器图 (C2) - AI Chat Service

' === 用户 ===
Person(user, "用户", "与 AI 助手进行自然语言对话")

' === 前端层 ===
System_Boundary(frontend_boundary, "前端层") {
    Container(angular_app, "Angular Web App", "Angular 20+ + TypeScript + SCSS", "提供 Web 用户界面，支持实时对话和消息历史")
}

' === 后端服务层 ===
System_Boundary(backend_boundary, "后端服务层 (Java Spring Boot)") {

    ' Interface Layer (Interface 层 - HTTP 接口)
    Container_Boundary(interface_layer, "Interface Layer") {
        Container(chat_controller, "ChatController", "Java REST Controller", "处理 HTTP 请求，参数验证，请求路由")
        Container(exception_handler, "GlobalExceptionHandler", "Java Exception Handler", "统一异常处理和错误响应")
        Container(request_dto, "Request/Response DTOs", "Java DTO", "ChatRequest, ChatResponse, MessageHistoryResponse, SessionInfo")
    }

    ' Application Layer (应用层 - 用例编排)
    Container_Boundary(application_layer, "Application Layer") {
        Container(send_message_usecase, "SendChatMessageUseCase", "Java Use Case", "发送聊天消息的业务用例")
        Container(chat_app_service, "ChatApplicationService", "Java Application Service", "聊天应用服务，协调领域对象和用例")
    }

    ' Domain Layer (领域层 - 核心业务逻辑)
    Container_Boundary(domain_layer, "Domain Layer") {
        Container(chat_session, "ChatSession", "Java Entity / Aggregate Root", "聊天会话实体，管理会话状态和消息列表")
        Container(chat_message, "ChatMessage", "Java Entity", "聊天消息实体，包含消息内容和类型")
        Container(ai_service, "AiChatService", "Java Domain Service", "AI 对话核心服务，处理业务规则")
        Container(domain_events, "Domain Events", "Java Records", "ChatMessageReceivedEvent, ChatResponseGeneratedEvent")

        ' Value Objects
        Container_Boundary(value_objects, "Value Objects") {
            Container(chat_session_id, "ChatSessionId", "Java Value Object", "会话唯一标识")
            Container(message_id, "MessageId", "Java Value Object", "消息唯一标识")
            Container(message_content, "MessageContent", "Java Value Object", "消息内容，验证和管理")
        }
    }

    ' Infrastructure Layer (基础设施层 - 外部适配)
    Container_Boundary(infrastructure_layer, "Infrastructure Layer") {
        Container(spring_ai_adapter, "SpringAiChatAdapter", "Java Adapter", "Spring AI 适配器，封装 DeepSeek API 调用")
        Container(spring_ai_service, "SpringAiChatService", "Java Service", "Spring AI 服务实现，处理流式响应")
        Container(in_memory_repo, "InMemoryChatSessionRepository", "Java Repository", "内存会话存储实现")
        Container(app_config, "ApplicationConfig", "Java Configuration", "应用配置，Bean 定义")
    }

    ' Application Ports (应用端口 - 接口定义)
    Container_Boundary(ports, "Application Ports") {
        Container(ai_chat_port, "AiChatPort", "Java Interface", "AI 聊天能力抽象")
        Container(session_repo_port, "ChatSessionRepositoryPort", "Java Interface", "会话仓储抽象")
    }
}

' === 数据层 ===
System_Boundary(data_boundary, "数据层") {
    ContainerDb(in_memory_store, "In-Memory Session Store", "ConcurrentHashMap", "会话数据内存存储")
}

' === 外部服务 ===
System_Boundary(external_boundary, "外部服务") {
    Container(ext_deepseek, "DeepSeek API", "REST API", "DeepSeek Chat 模型，LLM 推理服务")
}

' === 用户与前端关系 ===
Rel(user, angular_app, "对话交互", "HTTP/SSE")

' === 前端与后端关系 ===
Rel(angular_app, chat_controller, "HTTP 请求", "REST API")

' === Interface Layer 内部关系 ===
Rel(chat_controller, exception_handler, "异常传播")
Rel(chat_controller, request_dto, "请求/响应转换")
Rel(chat_controller, send_message_usecase, "调用用例")

' === Application Layer 内部关系 ===
Rel(send_message_usecase, chat_app_service, "编排")
Rel(chat_app_service, ai_chat_port, "依赖抽象")
Rel(chat_app_service, session_repo_port, "依赖抽象")
Rel(chat_app_service, chat_session, "操作领域对象")

' === Domain Layer 内部关系 ===
Rel(chat_session, chat_message, "包含")
Rel(chat_session, ai_service, "使用领域服务")
Rel(chat_session, domain_events, "发布事件")
Rel(ai_service, message_content, "验证内容")

' === Infrastructure Layer 关系 ===
Rel(spring_ai_adapter, ai_chat_port, "实现端口")
Rel(spring_ai_adapter, spring_ai_service, "依赖")
Rel(spring_ai_service, ext_deepseek, "调用 LLM API", "HTTP")

Rel(in_memory_repo, session_repo_port, "实现端口")
Rel(in_memory_repo, in_memory_store, "持久化")

' === Ports 与实现关系 ===
Rel(ai_chat_port, spring_ai_adapter, "实现")
Rel(session_repo_port, in_memory_repo, "实现")

' === 数据层关系 ===
Rel(in_memory_repo, in_memory_store, "读写会话数据")

SHOW_LEGEND()
@enduml
