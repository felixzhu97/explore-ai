@startuml AI-Test-Wardley-Map
skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 10
skinparam dpi 150
skinparam linetype ortho
skinparam rectangleRoundCorner 8

title AI-Test Platform - Wardley Map 技术演进

' ==================== EVOLUTION AXIS ====================
top to bottom direction

' 顶层：用户需求
package "用户需求 (Anchor)" <<anchor>> #FFFFFF {
    rectangle "ML 工程师 / 运维工程师 / 数据科学家" as user
}

' ==================== GENESIS 层 ====================
package "Genesis\n(创新阶段)" <<genesis>> #90EE90 {
    rectangle "动态任务路由\n(LangGraph)" as gen1
    rectangle "AIOps 智能分析" as gen2
    rectangle "LLMOps 训练编排" as gen3
}

' ==================== CUSTOM BUILT 层 ====================
package "Custom Built\n(定制开发)" <<custom-built>> #FFFACD {
    rectangle "Supervisor\n协调器" as cb1
    rectangle "K8s\n监控面板" as cb2
    rectangle "RAG\n检索管道" as cb3
    rectangle "视觉 AI\n推理服务" as cb4
    rectangle "ML Pipeline\n编排" as cb5
    rectangle "多语言\ni18n" as cb6
}

' ==================== PRODUCT 层 ====================
package "Product\n(商业产品)" <<product>> #ADD8E6 {
    rectangle "LangGraph" as prod1
    rectangle "Qdrant" as prod2
    rectangle "LangChain" as prod3
    rectangle "React 18" as prod4
    rectangle "YOLO11n" as prod5
    rectangle "PaddleOCR" as prod6
    rectangle "BLIP" as prod7
}

' ==================== COMMODITY 层 ====================
package "Commodity\n(标准化基础设施)" <<commodity>> #D3D3D3 {
    rectangle "云基础设施" as com1
    rectangle "Python\n/FastAPI" as com2
    rectangle "Node.js" as com3
    rectangle "Docker" as com4
    rectangle "PyTorch" as com5
    rectangle "HTTP\n/WebSocket" as com6
}

' ==================== 核心依赖关系 ====================

' 用户 → Custom Built
user -down-> cb1
user -down-> cb2
user -down-> cb3
user -down-> cb4

' Genesis → Custom Built
gen1 -right-> cb1
gen2 -right-> cb2
gen3 -right-> cb5

' Custom Built → Product
cb1 -right-> prod1
cb2 -right-> prod4
cb3 -right-> prod2
cb3 -right-> prod3
cb4 -right-> prod5
cb4 -right-> prod6
cb4 -right-> prod7

' Product → Commodity
prod1 -right-> prod3
prod1 -right-> com2
prod2 -right-> com4
prod3 -right-> com5
prod4 -right-> com3
prod5 -right-> com5
prod6 -right-> com5
prod7 -right-> com5

' Commodity 底层
com2 -right-> com1
com3 -right-> com1
com5 -right-> com1

' Custom Built 内部
cb1 -down-> cb3

' ==================== 图例 ====================
legend right
|= 颜色 |= 阶段 |
|<back:#90EE90>绿色</back>| Genesis |
|<back:#FFFACD>黄色</back>| Custom Built |
|<back:#ADD8E6>蓝色</back>| Product |
|<back:#D3D3D3>灰色</back>| Commodity |
endlegend

@enduml
