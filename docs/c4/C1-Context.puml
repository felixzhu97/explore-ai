@startuml C1-Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title 系统上下文图 (C1) - AI Chat Application with RAG

' ============================================================
' PEOPLE - 人员
' ============================================================
Person(user, "用户", "与 AI 助手进行自然语言对话, 上传文档进行问答")

' ============================================================
' AI Chat Application 系统边界
' ============================================================
System_Boundary(ai_chat_app, "AI Chat Application") {
    System(frontend, "Web Frontend", "Angular 19 + TypeScript + SCSS", "Web 用户界面")
    System(chat_backend, "AI Chat Backend", "Java 25 + Spring Boot 3.5", "会话管理、AI 对话处理")
    System(rag_backend, "RAG Backend", "Java 25 + Spring Boot 3.5 + pgvector", "文档管理、向量检索、RAG 增强问答")
}

' ============================================================
' EXTERNAL SYSTEMS - 外部系统
' ============================================================
System_Ext(deepseek_api, "DeepSeek API", "DeepSeek LLM + Embedding Service")
System_Ext(postgresql, "PostgreSQL + pgvector", "向量数据库，存储文档和向量嵌入")

' ============================================================
' RELATIONSHIPS - 关系
' ============================================================
Rel(user, frontend, "发送消息/上传文档/接收回复", "HTTPS")
Rel(frontend, chat_backend, "HTTP/SSE 请求", "HTTP/SSE")
Rel(frontend, rag_backend, "HTTP/SSE 请求(文档/RAG问答)", "HTTP/SSE")
Rel(chat_backend, deepseek_api, "LLM 调用", "HTTPS")
Rel(rag_backend, deepseek_api, "Embedding 生成/LLM 调用", "HTTPS")
Rel(rag_backend, postgresql, "向量搜索/文档存储", "JDBC")

SHOW_LEGEND()
@enduml
