@startuml C1-Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title 系统上下文图 (C1) - AI Chat Application

' ============================================================
' PEOPLE - 人员
' ============================================================
Person(user, "用户", "与 AI 助手进行自然语言对话")

' ============================================================
' AI Chat Application 系统边界
' ============================================================
System_Boundary(ai_chat_app, "AI Chat Application") {
    System(frontend, "Web Frontend", "Angular 19 + TypeScript + SCSS", "Web 用户界面")
    System(backend, "AI Chat Backend", "Java 25 + Spring Boot 3.5", "会话管理、AI 对话处理")
}

' ============================================================
' EXTERNAL SYSTEMS - 外部系统
' ============================================================
System_Ext(deepseek_api, "DeepSeek API", "DeepSeek LLM Service")

' ============================================================
' RELATIONSHIPS - 关系
' ============================================================
Rel(user, frontend, "发送消息/接收回复", "HTTPS")
Rel(frontend, backend, "HTTP/SSE 请求", "HTTP/SSE")
Rel(backend, deepseek_api, "LLM 调用", "HTTPS")

SHOW_LEGEND()
@enduml
