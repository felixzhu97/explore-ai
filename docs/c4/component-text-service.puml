@startuml C4-Component-Text-Service
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title 组件图 (C3) - Text 服务架构

Container_Boundary(text_service, "Text 服务") {

    ' === Presentation Layer ===
    System_Boundary(presentation, "Presentation Layer") {
        Component(api_router, "API Router", "FastAPI", "/chat, /completion")
        Component(schemas, "Schemas", "Pydantic", "请求/响应模型")
        Component(dependencies, "Dependencies", "FastAPI DI", "依赖注入")
    }

    ' === Application Layer ===
    System_Boundary(application, "Application Layer") {
        Component(chat_usecase, "ChatUseCase", "Python", "聊天用例")
        Component(completion_usecase, "CompletionUseCase", "Python", "补全用例")
        Component(chat_dto, "ChatDTO", "Pydantic", "聊天请求/响应")
        Component(completion_dto, "CompletionDTO", "Pydantic", "补全请求/响应")
    }

    ' === Domain Layer ===
    System_Boundary(domain, "Domain Layer") {
        Component(message_entity, "Message", "Python", "消息实体")
        Component(session_entity, "Session", "Python", "会话实体")
        Component(provider_value, "Provider", "Value Object", "LLM 提供者")
        Component(session_repository, "SessionRepository", "Port", "会话仓储接口")
        Component(exceptions, "Domain Exceptions", "Python", "领域异常")
    }

    ' === Infrastructure Layer ===
    System_Boundary(infrastructure, "Infrastructure Layer") {
        Component(llm_gateway, "LLMGateway", "Python + LangChain", "多 LLM 网关")
        Component(config_adapter, "ConfigAdapter", "Python", "配置适配器")
        Component(auth_adapter, "AuthAdapter", "Python", "认证适配器")
        Component(in_memory_repo, "InMemorySessionRepository", "Python", "内存会话存储")
    }
}

' === Presentation -> Application ===
Rel(api_router, chat_usecase, "执行用例")
Rel(api_router, completion_usecase, "执行用例")
Rel(api_router, dependencies, "依赖注入")

' === Application 层内部 ===
Rel(chat_usecase, chat_dto, "使用 DTO")
Rel(completion_usecase, completion_dto, "使用 DTO")
Rel(chat_usecase, llm_gateway, "调用 LLM")
Rel(completion_usecase, llm_gateway, "调用 LLM")

' === Application -> Domain ===
Rel(chat_usecase, message_entity, "创建/返回")
Rel(chat_usecase, session_entity, "管理会话")
Rel(chat_usecase, session_repository, "依赖接口")
Rel(completion_usecase, provider_value, "使用提供者")
Rel(api_router, exceptions, "异常处理")

' === Application -> Infrastructure ===
Rel(chat_usecase, in_memory_repo, "注入实现")
Rel(chat_usecase, auth_adapter, "注入")
Rel(llm_gateway, config_adapter, "使用配置")

' === Domain 层内部 ===
Rel(session_entity, message_entity, "聚合")
Rel(session_repository, session_entity, "持久化")

' === Infrastructure 层内部 ===
Rel(llm_gateway, provider_value, "使用配置")

' === 外部依赖 ===
System_Ext(ai_agents, "AI Agents Service", "Port 8003")
System_Ext(openai_api, "OpenAI API", "GPT-4")
System_Ext(claude_api, "Claude API", "Claude")
System_Ext(ollama, "Ollama", "本地 LLM")

Rel(llm_gateway, openai_api, "LLM 调用")
Rel(llm_gateway, claude_api, "LLM 调用")
Rel(llm_gateway, ollama, "本地推理")
Rel(api_router, ai_agents, "服务调用")

SHOW_LEGEND()
@enduml
