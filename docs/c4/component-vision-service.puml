@startuml C4-Component-Vision-Service
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title 组件图 (C4) - Vision Service DDD 架构

Container_Boundary(vision_service, "Vision Service") {

    ' === API Layer ===
    System_Boundary(api_layer, "API Layer") {
        Component(api_router, "API Router", "FastAPI", "路由定义")
        Component(video_api, "Video API", "FastAPI", "视频生成端点")
        Component(image_gen_api, "Image Gen API", "FastAPI", "图像生成端点")
        Component(vision_api, "Vision API", "FastAPI", "视觉识别端点")
    }

    ' === Application Layer ===
    System_Boundary(application_layer, "Application Layer") {
        Component(generate_video_uc, "GenerateVideoUseCase", "Python", "视频生成用例")
        Component(check_video_status_uc, "CheckVideoStatusUseCase", "Python", "视频状态查询用例")
    }

    ' === Application DTOs ===
    System_Boundary(application_dtos, "Application DTOs") {
        Component(video_dtos, "VideoDTOs", "Pydantic", "视频请求/响应DTO")
        Component(image_dtos, "ImageDTOs", "Pydantic", "图像请求/响应DTO")
        Component(vision_dtos, "VisionDTOs", "Pydantic", "视觉请求/响应DTO")
    }

    ' === Domain Layer ===
    System_Boundary(domain_layer, "Domain Layer") {
        ' Domain Entities
        Component(video_task_entity, "VideoTask", "Entity", "视频任务实体\n状态机: PENDING→PROCESSING→COMPLETED/FAILED")
        Component(image_entity, "Image", "Entity", "图像实体")

        ' Value Objects
        Component(video_config_vo, "VideoConfig", "Value Object", "视频配置(不可变)")
        Component(dimensions_vo, "Dimensions", "Value Object", "尺寸值对象")

        ' Domain Services
        Component(video_gen_service, "VideoGenerationService", "Domain Service", "视频生成编排")
        Component(image_gen_service, "ImageGenerationService", "Domain Service", "图像生成编排")

        ' Domain Events
        Component(video_events, "VideoEvents", "Domain Events", "VideoTaskCreatedEvent\nVideoTaskCompletedEvent\nVideoTaskFailedEvent")
    }

    ' === Infrastructure Layer ===
    System_Boundary(infrastructure_layer, "Infrastructure Layer") {
        ' Dependency Injection
        Component(di_container, "DependencyContainer", "Python", "依赖注入容器")

        ' Provider Interfaces
        Component(provider_interface, "VideoProvider", "Protocol", "Provider接口定义")

        ' Provider Implementations
        Component(provider_factory, "ProviderFactory", "Python", "Provider工厂")
        Component(kling_provider, "KlingProvider", "Python", "快手可灵")
        Component(runway_provider, "RunwayProvider", "Python", "Runway ML")
        Component(pika_provider, "PikaProvider", "Python", "Pika Labs")
        Component(sora_provider, "SoraProvider", "Python", "OpenAI Sora")
        Component(replicate_provider, "ReplicateProvider", "Python", "Replicate通用")
        Component(mock_provider, "MockProvider", "Python", "测试Mock")
    }

    ' === Configuration ===
    System_Boundary(config_layer, "Configuration") {
        Component(base_config, "BaseConfig", "Pydantic Settings", "基础配置管理")
    }

    ' === Vision Models (Legacy/Supporting) ===
    System_Boundary(models_layer, "ML Models") {
        Component(yolo_detector, "YOLODetector", "PyTorch", "目标检测")
        Component(blip_captioner, "BLIPCaptioner", "PyTorch", "图像描述")
        Component(easyocr, "EasyOCRProcessor", "EasyOCR", "文字识别")
        Component(t2i_generator, "TextToImage", "Python", "文生图模型")
    }
}

' === API → Application Layer 关系 ===
Rel(api_router, video_api, "路由")
Rel(api_router, image_gen_api, "路由")
Rel(api_router, vision_api, "路由")

Rel(video_api, generate_video_uc, "调用")
Rel(video_api, check_video_status_uc, "调用")
Rel(video_api, video_dtos, "使用")

' === Application → Domain Layer 关系 ===
Rel(generate_video_uc, video_gen_service, "依赖")
Rel(generate_video_uc, video_task_entity, "创建")
Rel(generate_video_uc, video_config_vo, "使用")

Rel(check_video_status_uc, video_gen_service, "调用")
Rel(check_video_status_uc, video_task_entity, "更新状态")

' === Domain Services → Entities/Value Objects ===
Rel(video_gen_service, video_task_entity, "创建/更新")
Rel(video_gen_service, video_config_vo, "使用")
Rel(video_gen_service, video_events, "发布事件")

' === Dependency Injection ===
Rel(di_container, video_gen_service, "注入")
Rel(di_container, image_gen_service, "注入")
Rel(di_container, generate_video_uc, "注入")
Rel(di_container, check_video_status_uc, "注入")

' === Provider 实现 ===
Rel(provider_factory, provider_interface, "返回")
Rel(provider_factory, kling_provider, "创建")
Rel(provider_factory, runway_provider, "创建")
Rel(provider_factory, pika_provider, "创建")
Rel(provider_factory, sora_provider, "创建")
Rel(provider_factory, replicate_provider, "创建")
Rel(provider_factory, mock_provider, "创建")

Rel(kling_provider, provider_interface, "实现")
Rel(runway_provider, provider_interface, "实现")
Rel(pika_provider, provider_interface, "实现")
Rel(sora_provider, provider_interface, "实现")
Rel(replicate_provider, provider_interface, "实现")
Rel(mock_provider, provider_interface, "实现")

' === Domain Service → Provider Interface ===
Rel(video_gen_service, provider_interface, "依赖(注入)")
Rel(di_container, provider_interface, "注入实现")

' === Configuration ===
Rel(base_config, video_config_vo, "配置映射")
Rel(di_container, base_config, "读取配置")

' === Vision API → Models ===
Rel(vision_api, yolo_detector, "使用")
Rel(vision_api, blip_captioner, "使用")
Rel(vision_api, easyocr, "使用")

SHOW_LEGEND()
@enduml
