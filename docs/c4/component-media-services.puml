@startuml C4-Component-Media-Services
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title 组件图 (C3) - 媒体服务架构 (Clean Architecture)

Container_Boundary(media_services, "Media Services") {

    ' === TTS Service ===
    System_Boundary(tts_service, "TTS Service") {
        Component(tts_router, "TTS Router", "FastAPI", "语音合成端点")
        Component(tts_app_service, "TTSApplicationService", "Python", "应用服务")
        Component(synthesize_usecase, "SynthesizeSpeechUseCase", "Python", "语音合成用例")
        Component(voice_entity, "Voice Entity", "Python", "语音实体")
        Component(synthesis_entity, "Synthesis Entity", "Python", "合成实体")
        Component(tts_provider_port, "TTSProviderPort", "Protocol", "Provider 端口")
        Component(tts_factory, "TTSFactory", "Python", "Provider 工厂")
        Component(azure_tts, "AzureTTSAdapter", "Python", "Azure 实现")
        Component(google_tts, "GoogleTTSAdapter", "Python", "Google 实现")
        Component(elevenlabs_tts, "ElevenLabsAdapter", "Python", "ElevenLabs 实现")
        Component(edge_tts, "EdgeTTSAdapter", "Python", "Edge 实现")
        Component(coqui_tts, "CoquiTTSAdapter", "Python", "Coqui 实现")
    }

    ' === Text Service ===
    System_Boundary(text_service, "Text Service") {
        Component(text_router, "API Router", "FastAPI", "/chat, /completion")
        Component(chat_usecase, "ChatUseCase", "Python", "聊天用例")
        Component(message_entity, "Message Entity", "Python", "消息实体")
        Component(session_entity, "Session Entity", "Python", "会话实体")
        Component(session_repo, "SessionRepository", "Port", "会话仓储接口")
        Component(llm_gateway, "LLMGateway", "Python", "LLM 网关")
        Component(provider_vo, "Provider", "Value Object", "提供者配置")
    }

    ' === Media Gen Service ===
    System_Boundary(media_gen, "Media Gen Service") {

        ' Presentation Layer
        Component(media_app, "FastAPI App", "FastAPI", "应用入口")
        Component(image_routes, "Image Routes", "FastAPI", "/image/generate")
        Component(health_routes, "Health Routes", "FastAPI", "/health, /cache/clear")

        ' Application Layer
        Component(gen_usecase, "GenerateImageUseCase", "Python", "图像生成用例")
        Component(gen_request_dto, "GenerationRequestDTO", "Pydantic", "请求模型")
        Component(gen_response_dto, "GenerationResponseDTO", "Pydantic", "响应模型")

        ' Domain Layer
        Component(gen_image_entity, "GeneratedImage", "Entity", "图像实体")
        Component(gen_params, "GenerationParams", "Value Object", "生成参数")
        Component(model_cache_port, "ModelCacheRepository", "Port", "模型缓存接口")
        Component(image_encoder_port, "ImageEncoderPort", "Port", "图像编码接口")
        Component(domain_errors, "Domain Errors", "Python", "领域错误类型")

        ' Infrastructure Layer
        Component(sd_adapter, "StableDiffusionAdapter", "Python", "SD Pipeline 适配器")
        Component(image_encoder, "ImageEncoderAdapter", "Python", "Base64 编码")
        Component(device_selector, "Device Selector", "Python", "CUDA/MPS/CPU")
        Component(hf_config, "HuggingFace Config", "Python", "HF 配置")
        Component(settings, "Settings", "Pydantic Settings", "环境变量配置")
    }
}

' === TTS Service 内部关系 (Clean Architecture) ===
Rel(tts_router, tts_app_service, "委托")
Rel(tts_app_service, synthesize_usecase, "编排")
Rel(synthesize_usecase, tts_provider_port, "依赖接口")
Rel(tts_app_service, tts_factory, "创建 Provider")
Rel(tts_factory, azure_tts, "创建")
Rel(tts_factory, google_tts, "创建")
Rel(tts_factory, elevenlabs_tts, "创建")
Rel(tts_factory, edge_tts, "创建")
Rel(tts_factory, coqui_tts, "创建")

' === Text Service 内部关系 (Clean Architecture) ===
Rel(text_router, chat_usecase, "执行用例")
Rel(chat_usecase, message_entity, "创建实体")
Rel(chat_usecase, session_entity, "管理会话")
Rel(chat_usecase, session_repo, "依赖接口")
Rel(chat_usecase, llm_gateway, "调用 LLM")

' === Media Gen Service 内部关系 (Clean Architecture) ===
' Presentation -> Application
Rel(media_app, image_routes, "注册路由")
Rel(image_routes, gen_usecase, "执行用例")
Rel(image_routes, health_routes, "包含")

' Application -> Domain
Rel(gen_usecase, model_cache_port, "依赖接口")
Rel(gen_usecase, image_encoder_port, "依赖接口")
Rel(gen_usecase, gen_image_entity, "创建实体")

' Application -> Infrastructure
Rel(gen_usecase, sd_adapter, "注入实现")
Rel(gen_usecase, image_encoder, "注入实现")

' Infrastructure -> External
Rel(sd_adapter, hf_config, "配置")
Rel(sd_adapter, device_selector, "设备选择")

' === 服务间关系 ===
Rel(tts_service, text_service, "调用 LLM", "HTTP")
Rel(text_service, media_gen, "图像生成", "HTTP")

' === AI Agents 与服务关系 ===
System_Ext(ai_agents_tts, "AI Agents - TTS Agent", "TTS Tools")
System_Ext(ai_agents_video, "AI Agents - Video Agent", "Video Tools")

Rel(ai_agents_tts, tts_service, "调用 TTS API")
Rel(ai_agents_video, media_gen, "调用媒体生成")

SHOW_LEGEND()
@enduml
