@startuml C4-Component-Frontend
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title 组件图 (C3) - Web Frontend (Angular 20+) 架构

Container_Boundary(frontend, "Web Frontend") {

    ' === App Layer ===
    Container_Boundary(app_layer, "App Layer") {
        Component(app_root, "App", "Angular Component", "根组件，路由和状态管理")
        Component(router, "Router", "Angular Router", "路由配置：/agents, /infra, /rag, /tts, /video")
        Component(i18n, "I18nService", "Angular Service", "国际化：i18next 集成")
    }

    ' === Main Layout ===
    Container_Boundary(layout, "Layout Components") {
        Component(nav, "NavComponent", "Angular Component", "导航栏")
        Component(header, "HeaderComponent", "Angular Component", "页头")
        Component(sidebar, "SidebarComponent", "Angular Component", "侧边栏")
    }

    ' === AI Hub ===
    Container_Boundary(ai_hub, "AI Hub Module") {
        Component(ai_hub_page, "AIHubPageComponent", "Angular Component", "AI 中心主页")
        Component(agent_selector, "AgentSelectorComponent", "Angular Component", "Agent 选择器")
    }

    ' === AI Infra Panel ===
    Container_Boundary(ai_infra, "AI Infra Panel") {
        Component(ai_infra_panel, "AIInfraPanelComponent", "Angular Component", "AI 基础设施面板")
        Component(agent_panel, "AgentPanelComponent", "Angular Component", "通用 Agent 面板容器")
        Component(segmented_control, "SegmentedControlComponent", "Angular Component", "分段选择控件：切换 Agent 类型")
    }

    ' === Agent Chat Components ===
    Container_Boundary(chat_components, "Agent Chat Components") {
        Component(agent_chat, "AgentChatComponent", "Angular Component + Signals", "通用智能体聊天组件，支持 SSE 流式响应")
        Component(chat_message, "ChatMessageComponent", "Angular Component", "聊天消息展示组件")
        Component(tool_result, "ToolResultComponent", "Angular Component", "工具执行结果展示")
        Component(status_badge, "StatusBadgeComponent", "Angular Component", "状态徽章组件")
        Component(streaming_text, "StreamingTextComponent", "Angular Component", "流式文本展示组件")
    }

    ' === RAG Components ===
    Container_Boundary(rag_components, "RAG Components") {
        Component(rag_page, "RAGPageComponent", "Angular Component", "RAG 页面")
        Component(rag_chat, "RAGChatComponent", "Angular Component", "RAG 聊天组件")
        Component(document_list, "DocumentListComponent", "Angular Component", "文档列表")
        Component(document_upload, "DocumentUploadComponent", "Angular Component", "文档上传")
    }

    ' === TTS Components ===
    Container_Boundary(tts_components, "TTS Components") {
        Component(tts_panel, "TTSPanelComponent", "Angular Component", "TTS 面板")
        Component(voice_selector, "VoiceSelectorComponent", "Angular Component", "语音选择器")
        Component(audio_player, "AudioPlayerComponent", "Angular Component", "音频播放器")
        Component(speed_control, "SpeedControlComponent", "Angular Component", "语速控制")
    }

    ' === Video Components ===
    Container_Boundary(video_components, "Video Components") {
        Component(video_panel, "VideoPanelComponent", "Angular Component", "视频生成面板")
        Component(video_preview, "VideoPreviewComponent", "Angular Component", "视频预览组件")
        Component(prompt_editor, "PromptEditorComponent", "Angular Component", "提示词编辑器")
        Component(generation_progress, "GenerationProgressComponent", "Angular Component", "生成进度展示")
    }

    ' === Shared Components ===
    Container_Boundary(shared, "Shared Components") {
        Component(card, "CardComponent", "Angular Component", "卡片容器组件")
        Component(button, "ButtonComponent", "Angular Component", "按钮组件")
        Component(input_field, "InputFieldComponent", "Angular Component", "输入框组件")
        Component(select_dropdown, "SelectDropdownComponent", "Angular Component", "下拉选择组件")
        Component(loader, "LoaderComponent", "Angular Component", "加载状态组件")
        Component(image_uploader, "ImageUploaderComponent", "Angular Component", "图片上传组件")
        Component(segmented_ctrl_shared, "SegmentedControlComponent", "Angular Component", "分段选择控件")
    }

    ' === Services ===
    Container_Boundary(services, "Services") {
        Component(ai_service, "AiService", "Angular Service", "AI 服务封装：chat, chatStream, ragChat, synthesizeSpeech 等")
        Component(api_service, "ApiService", "Angular Service", "通用 API 服务")
        Component(http_client, "HttpClient", "Angular Service", "HTTP 请求客户端")
        Component(sse_client, "SSE Client", "Native + Fetch", "Server-Sent Events：流式响应处理")
    }

    ' === Infrastructure ===
    Container_Boundary(infrastructure, "Infrastructure") {
        Component(theme, "Theme", "CSS Variables", "主题配置")
        Component(store, "Store", "Signals/State", "状态管理")
    }
}

' === AI Gateway ===
Container_Boundary(backend, "AI Gateway (Java Spring Boot)") {
    Component(agent_controller, "AgentController", "REST API", "Agent HTTP 端点")
    Component(supervisor_sse, "Supervisor SSE", "SSE Endpoint", "/api/agents/supervisor/invoke/sse")
    Component(k8s_sse, "K8s SSE", "SSE Endpoint", "/api/agents/kubernetes/invoke/sse")
    Component(monitoring_sse, "Monitoring SSE", "SSE Endpoint", "/api/agents/monitoring/invoke/sse")
    Component(llmops_sse, "LLMOps SSE", "SSE Endpoint", "/api/agents/llmops/invoke/sse")
    Component(aiops_sse, "AIOps SSE", "SSE Endpoint", "/api/agents/aiops/invoke/sse")
    Component(vectordb_sse, "VectorDB SSE", "SSE Endpoint", "/api/agents/vector/invoke/sse")
}

' === 外部服务 ===
System_Boundary(external_services, "External Services") {
    Component(text_service, "Text Service", "Python FastAPI", "文本处理/LLM")
    Component(vision_service, "Vision Service", "Python FastAPI", "视觉 AI")
    Component(tts_service, "TTS Service", "Python FastAPI", "语音合成")
    Component(rag_service, "RAG Service", "Python FastAPI", "文档检索")
    Component(image_service, "Image Gen Service", "Python FastAPI", "图像生成")
}

' === App 层关系 ===
Rel(app_root, router, "路由")
Rel(app_root, i18n, "国际化")
Rel(app_root, nav, "渲染")
Rel(app_root, header, "渲染")

' === 页面关系 ===
Rel(router, ai_hub_page, "导航到")
Rel(router, rag_page, "导航到")
Rel(router, ai_infra_panel, "嵌入")

' === AI Hub 关系 ===
Rel(ai_hub_page, agent_selector, "包含")
Rel(ai_hub_page, ai_infra_panel, "嵌入")

' === AI Infra Panel 关系 ===
Rel(ai_infra_panel, segmented_control, "切换 Agent")
Rel(ai_infra_panel, agent_panel, "包裹")
Rel(ai_infra_panel, agent_chat, "嵌入")

' === Agent Chat 关系 ===
Rel(agent_chat, chat_message, "渲染消息")
Rel(agent_chat, tool_result, "渲染工具")
Rel(agent_chat, status_badge, "显示状态")
Rel(agent_chat, streaming_text, "流式展示")
Rel(agent_chat, sse_client, "SSE 流")

' === SSE Client -> Backend ===
Rel(sse_client, supervisor_sse, "SSE 流式请求")
Rel(sse_client, k8s_sse, "SSE 流式请求")
Rel(sse_client, monitoring_sse, "SSE 流式请求")
Rel(sse_client, llmops_sse, "SSE 流式请求")
Rel(sse_client, aiops_sse, "SSE 流式请求")
Rel(sse_client, vectordb_sse, "SSE 流式请求")

' === AiService -> API ===
Rel(ai_service, http_client, "HTTP 请求")
Rel(ai_service, sse_client, "流式请求")
Rel(api_service, http_client, "HTTP 请求")

' === RAG 组件关系 ===
Rel(rag_page, rag_chat, "包含")
Rel(rag_chat, document_list, "文档列表")
Rel(rag_chat, document_upload, "上传")
Rel(rag_chat, ai_service, "RAG API")

' === TTS 组件关系 ===
Rel(tts_panel, voice_selector, "选择语音")
Rel(tts_panel, audio_player, "播放音频")
Rel(tts_panel, speed_control, "控制速度")
Rel(voice_selector, select_dropdown, "使用")
Rel(tts_panel, ai_service, "TTS API")

' === Video 组件关系 ===
Rel(video_panel, prompt_editor, "编辑提示")
Rel(video_panel, video_preview, "预览")
Rel(video_panel, generation_progress, "进度")
Rel(prompt_editor, input_field, "输入")
Rel(video_panel, ai_service, "Video API")

' === 共享组件使用 ===
Rel(app_root, card, "使用")
Rel(app_root, button, "使用")
Rel(app_root, loader, "使用")

' === Backend -> External Services ===
Rel(agent_controller, text_service, "转发请求")
Rel(agent_controller, vision_service, "转发请求")
Rel(agent_controller, tts_service, "转发请求")
Rel(agent_controller, rag_service, "转发请求")
Rel(agent_controller, image_service, "转发请求")

SHOW_LEGEND()
@enduml
