@startuml C4-Component-TTS-Service
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title 组件图 (C3) - TTS 服务架构

Container_Boundary(tts_service, "TTS 服务") {

    ' === Presentation Layer ===
    System_Boundary(presentation, "Presentation Layer") {
        Component(tts_router, "TTS Router", "FastAPI", "/tts/synthesize, /tts/stream, /tts/voices")
        Component(dependencies, "Dependencies", "FastAPI DI", "依赖注入配置")
    }

    ' === Application Layer ===
    System_Boundary(application, "Application Layer") {
        Component(tts_app_service, "TTSApplicationService", "Python", "应用服务编排")
        Component(synthesize_usecase, "SynthesizeSpeechUseCase", "Python", "语音合成用例")
        Component(stream_usecase, "StreamSpeechUseCase", "Python", "流式语音用例")
        Component(list_voices_usecase, "ListVoicesUseCase", "Python", "获取语音列表")
        Component(get_health_usecase, "GetHealthUseCase", "Python", "健康检查用例")
        Component(synthesis_dto, "SynthesisDTOs", "Pydantic", "请求/响应模型")
    }

    ' === Domain Layer ===
    System_Boundary(domain, "Domain Layer") {
        Component(voice_entity, "Voice", "Python", "语音实体")
        Component(synthesis_entity, "Synthesis", "Python", "合成结果实体")
        Component(audio_config, "AudioConfig", "Python", "音频配置值对象")
        Component(synthesis_service, "SynthesisService", "Domain Service", "合成业务逻辑")
        Component(tts_provider_port, "TTSProviderPort", "Protocol", "Provider 端口接口")
    }

    ' === Infrastructure Layer ===
    System_Boundary(infrastructure, "Infrastructure Layer") {
        Component(tts_factory, "TTSFactory", "Python", "Provider 工厂")
        Component(azure_adapter, "AzureTTSAdapter", "Python", "Azure TTS 实现")
        Component(google_adapter, "GoogleTTSAdapter", "Python", "Google TTS 实现")
        Component(elevenlabs_adapter, "ElevenLabsAdapter", "Python", "ElevenLabs 实现")
        Component(edge_adapter, "EdgeTTSAdapter", "Python", "Edge TTS 实现")
        Component(coqui_adapter, "CoquiTTSAdapter", "Python", "Coqui 开源实现")
        Component(base_adapter, "BaseTTSAdapter", "Python", "Adapter 基类")
    }
}

' === Presentation -> Application ===
Rel(tts_router, tts_app_service, "委托", "Depends")
Rel(tts_router, dependencies, "使用")

' === Application 层关系 ===
Rel(tts_app_service, synthesize_usecase, "编排")
Rel(tts_app_service, stream_usecase, "编排")
Rel(tts_app_service, list_voices_usecase, "编排")
Rel(tts_app_service, get_health_usecase, "编排")
Rel(synthesize_usecase, synthesis_dto, "使用 DTO")
Rel(stream_usecase, synthesis_dto, "使用 DTO")

' === Application -> Domain ===
Rel(synthesize_usecase, tts_provider_port, "依赖接口")
Rel(stream_usecase, tts_provider_port, "依赖接口")
Rel(tts_app_service, voice_entity, "返回实体")
Rel(tts_app_service, synthesis_service, "调用领域服务")

' === Application -> Infrastructure ===
Rel(synthesize_usecase, azure_adapter, "注入")
Rel(synthesize_usecase, google_adapter, "注入")
Rel(synthesize_usecase, elevenlabs_adapter, "注入")
Rel(synthesize_usecase, edge_adapter, "注入")
Rel(synthesize_usecase, coqui_adapter, "注入")
Rel(tts_app_service, tts_factory, "创建 Provider")

' === Domain 层内部 ===
Rel(tts_provider_port, voice_entity, "使用")
Rel(tts_provider_port, synthesis_entity, "返回")
Rel(synthesis_service, audio_config, "使用配置")

' === Infrastructure 层内部 ===
Rel(tts_factory, azure_adapter, "创建")
Rel(tts_factory, google_adapter, "创建")
Rel(tts_factory, elevenlabs_adapter, "创建")
Rel(tts_factory, edge_adapter, "创建")
Rel(tts_factory, coqui_adapter, "创建")
Rel(tts_factory, base_adapter, "继承")

' === 外部依赖 ===
System_Ext(ai_agents, "AI Agents Service", "Port 8003")
System_Ext(azure_cloud, "Azure Cloud", "Azure TTS API")
System_Ext(google_cloud, "Google Cloud", "Google Cloud TTS API")
System_Ext(elevenlabs_api, "ElevenLabs API", "ElevenLabs API")

Rel(tts_router, ai_agents, "服务调用")
Rel(azure_adapter, azure_cloud, "API 调用")
Rel(google_adapter, google_cloud, "API 调用")
Rel(elevenlabs_adapter, elevenlabs_api, "API 调用")

SHOW_LEGEND()
@enduml
