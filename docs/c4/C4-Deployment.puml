@startuml C4-Deployment
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Deployment.puml

LAYOUT_WITH_LEGEND()

title Deployment Diagram - Local Development Environment

' ============================================================
' DEVELOPER WORKSTATION - 本地开发机器
' ============================================================
Person_Ext(user, "Developer / End User", "Browses the Angular web application from a browser")

Deployment_Node(developer_workstation, "Developer Workstation", "localhost") {

    ' ============================================================
    ' Docker Engine - PostgreSQL + pgvector
    ' ============================================================
    Deployment_Node(docker_engine, "Docker Engine", "Docker") {
        ContainerDb(postgresql_pgvector, "PostgreSQL + pgvector", "pgvector/pgvector:pg17", "Documents, vectors, metadata", "5432")
    }

    ' ============================================================
    ' Java Runtime - Spring Boot Backend
    ' ============================================================
    Deployment_Node(java_runtime, "JDK 25 (Gradle Build)", "eclipse-temurin:25-jdk-alpine / jre-alpine") {
        Container(backend, "Spring Boot Backend", "eclipse-temurin:25-jre-alpine", "AI Chat + RAG + Tool Calling\nSpring Boot 4.0 / Java 25 / Spring AI 2.0", "9000")
    }

    ' ============================================================
    ' Node.js - Angular Dev Server
    ' ============================================================
    Deployment_Node(node_runtime, "Node 22 + pnpm", "Node 22") {
        Container(angular_dev, "Angular 22 Dev Server", "Angular CLI", "Web UI\nproxy.conf.json: /api/* → localhost:9000", "4200")
    }
}

' ============================================================
' EXTERNAL SERVICES - 外部服务
' ============================================================
Deployment_Node(deepseek_node, "DeepSeek API", "HTTPS") {
    Container_Ext(deepseek_api, "DeepSeek API", "REST API", "LLM Chat + Text Embedding", "HTTPS")
}

Deployment_Node(ollama_node, "Ollama (Local or Docker)", "localhost:11434") {
    Container_Ext(ollama_svc, "Ollama", "REST API", "Local Embedding Model (nomic-embed-text)", "11434")
}

' ============================================================
' RELATIONSHIPS - 关系
' ============================================================

' User interacts with Angular
Rel(user, angular_dev, "Browses (HTTP)", "TCP")

' Angular proxy to Backend
Rel(angular_dev, backend, "/api/* → localhost:9000", "HTTP/SSE")

' Backend to PostgreSQL
Rel(backend, postgresql_pgvector, "JDBC", "TCP :5432")

' Backend to DeepSeek API
Rel_D(backend, deepseek_api, "LLM Chat + Embedding", "HTTPS")

' Backend to Ollama
Rel(backend, ollama_svc, "Embedding Generation", "HTTP :11434")

SHOW_LEGEND()
@enduml
