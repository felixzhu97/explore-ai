@startuml C3-Component-Backend
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title 组件图 (C3) - AI Chat Service 后端

' ============================================================
' SYSTEM BOUNDARY - 后端系统边界
' ============================================================
System_Boundary(backend_system, "AI Chat Service 后端 (Java Spring Boot)") {

    ' ============================================================
    ' Interface Layer - 接口层
    ' ============================================================
    Container_Boundary(interface_layer, "Interface Layer") {
        Component(chat_controller, "ChatController", "@RestController", "处理 HTTP 请求，参数验证，请求路由")
        Component(global_exception_handler, "GlobalExceptionHandler", "@RestControllerAdvice", "统一异常处理，返回标准化错误响应")
        Component(chat_request_dto, "ChatRequest", "Java Record", "聊天请求 DTO")
        Component(chat_response_dto, "ChatResponse", "Java Record", "聊天响应 DTO")
        Component(message_history_response, "MessageHistoryResponse", "Java Record", "消息历史响应 DTO")
        Component(session_info_dto, "SessionInfo", "Java Record", "会话信息 DTO")
    }

    ' ============================================================
    ' Application Layer - 应用层
    ' ============================================================
    Container_Boundary(application_layer, "Application Layer") {
        Component(send_chat_usecase, "SendChatMessageUseCase", "Java Class", "发送聊天消息用例")
        Component(chat_app_service, "ChatApplicationService", "@Service", "聊天应用服务，协调业务用例")

        ' Ports (依赖倒置接口)
        Container_Boundary(ports, "Ports") {
            Component(ai_chat_port, "AiChatPort", "Java Interface", "AI 聊天能力抽象接口")
            Component(chat_session_repo_port, "ChatSessionRepositoryPort", "Java Interface", "会话仓储抽象接口")
        }
    }

    ' ============================================================
    ' Domain Layer - 领域层 (核心业务)
    ' ============================================================
    Container_Boundary(domain_layer, "Domain Layer") {

        ' 聚合根和实体
        Component(chat_session, "ChatSession", "Aggregate Root", "聊天会话聚合根，管理消息列表")
        Component(chat_message, "ChatMessage", "Entity", "聊天消息实体")

        ' 领域服务
        Component(ai_chat_service, "AiChatService", "Domain Service Interface", "AI 对话核心服务接口")

        ' 值对象
        Container_Boundary(value_objects, "Value Objects") {
            Component(chat_session_id, "ChatSessionId", "Java Record", "会话唯一标识")
            Component(message_id, "MessageId", "Java Record", "消息唯一标识")
            Component(message_content, "MessageContent", "Java Record", "消息内容")
        }

        ' 领域事件
        Container_Boundary(domain_events, "Domain Events") {
            Component(chat_message_received_event, "ChatMessageReceivedEvent", "Java Record", "消息接收事件")
            Component(chat_response_generated_event, "ChatResponseGeneratedEvent", "Java Record", "响应生成事件")
            Component(domain_event_base, "DomainEvent", "Java Sealed Class", "领域事件基类")
        }

        ' 领域异常
        Container_Boundary(domain_exceptions, "Domain Exceptions") {
            Component(ai_service_exception, "AiServiceException", "Exception", "AI 服务异常")
            Component(chat_session_not_found, "ChatSessionNotFoundException", "Exception", "会话未找到异常")
        }

        Component(domain_constants, "DomainConstants", "Java Class", "领域常量")
    }

    ' ============================================================
    ' Infrastructure Layer - 基础设施层
    ' ============================================================
    Container_Boundary(infrastructure_layer, "Infrastructure Layer") {

        ' AI 适配器
        Container_Boundary(ai_adapters, "AI Adapters") {
            Component(spring_ai_adapter, "SpringAiChatAdapter", "@Service", "AI 端口适配器，实现 AiChatPort")
            Component(spring_ai_service_impl, "SpringAiChatService", "@Service", "Spring AI 服务实现，封装 ChatModel")

            ' Spring AI 内部组件
            Container_Boundary(spring_ai_internals, "Spring AI Internals") {
                Component(chat_model, "ChatModel", "Spring AI Interface", "ChatModel 接口")
                Component(deepseek_model, "DeepSeekChatModel", "Implementation", "DeepSeek ChatModel 实现")
                Component(prompt, "Prompt", "Class", "提示词构建器")
                Component(chat_response, "ChatResponse", "Class", "Chat 响应封装")
            }
        }

        ' 持久化适配器
        Container_Boundary(persistence_adapters, "Persistence Adapters") {
            Component(in_memory_session_repo, "InMemoryChatSessionRepository", "@Repository", "内存会话仓储实现")
        }

        ' 配置
        Component(application_config, "ApplicationConfig", "@Configuration", "应用配置，Bean 定义")
    }
}

' ============================================================
' EXTERNAL SYSTEMS - 外部系统
' ============================================================
System_Boundary(external_systems, "External Systems") {
    Component(deepseek_api, "DeepSeek API", "REST API", "DeepSeek Chat Completions API")
    Component(concurrent_hash_map, "ConcurrentHashMap", "Java Concurrent API", "线程安全内存存储")
}

' ============================================================
' RELATIONSHIPS - 关系定义
' ============================================================

' Interface -> Application
Rel(chat_controller, send_chat_usecase, "调用用例")
Rel(chat_controller, chat_response_dto, "转换响应")
Rel(chat_controller, global_exception_handler, "委托异常")

' Application Layer
Rel(send_chat_usecase, chat_app_service, "编排")
Rel(chat_app_service, ai_chat_port, "依赖抽象")
Rel(chat_app_service, chat_session_repo_port, "依赖抽象")
Rel(chat_app_service, chat_session, "操作领域对象")

' Ports 实现
Rel(ai_chat_port, spring_ai_adapter, "由...实现")
Rel(chat_session_repo_port, in_memory_session_repo, "由...实现")

' Infrastructure Layer
Rel(spring_ai_adapter, spring_ai_service_impl, "组合")
Rel(spring_ai_service_impl, chat_model, "使用")
Rel(chat_model, deepseek_model, "委托实现")

Rel(in_memory_session_repo, chat_session, "持久化")

' Domain Layer 内部
Rel(chat_session, chat_message, "包含 (1:N)")
Rel(chat_session, domain_event_base, "发布事件")
Rel(chat_session, ai_chat_service, "使用领域服务")
Rel(chat_message, message_content, "封装内容")

' 外部调用
Rel(spring_ai_service_impl, deepseek_api, "HTTP 调用")
Rel(in_memory_session_repo, concurrent_hash_map, "使用存储")

SHOW_LEGEND()
@enduml
