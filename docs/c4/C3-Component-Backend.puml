@startuml C3-Component-Backend
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title 组件图 (C3) - AI Platform Backend (Spring Boot 4.1 / Spring AI 2.0)

' ============================================================
' SYSTEM BOUNDARY - 后端系统边界
' ============================================================
System_Boundary(backend, "AI Platform Backend (Spring Boot 4.1 / Java 25 / Spring AI 2.0)") {

    ' ============================================================
    ' INTERFACE LAYER
    ' ============================================================
    Container_Boundary(iface_layer, "Interface Layer") {
        ' Controllers
        Component(chat_ctrl, "ChatController", "@RestController", "聊天 HTTP/SSE 请求，/api/chat/*")
        Component(rag_ctrl, "RagController", "@RestController", "RAG HTTP/SSE 请求，/api/rag/*")
        Component(agent_ctrl, "AgentInvokeController", "@RestController", "9-Tab MCP Agent SSE，/api/mcp/invoke")
        Component(fc_ctrl, "FunctionCallController", "@RestController", "OpenAI 风格 Function Call，/api/function-call/*")
        Component(ex_handler, "GlobalExceptionHandler", "@RestControllerAdvice", "统一异常处理")

        ' DTOs - functioncall sub-package
        Component(chat_req_dto, "ChatRequest", "Java Record", "聊天请求 DTO")
        Component(chat_resp_dto, "ChatResponse", "Java Record", "聊天响应 DTO")
        Component(sess_info_dto, "SessionInfo", "Java Record", "会话信息 DTO")
        Component(rag_chat_req, "RagChatRequest", "Java Record", "RAG 聊天请求")
        Component(rag_chat_resp, "RagChatResponse", "Java Record", "RAG 聊天响应")
        Component(doc_upload_req, "DocumentUploadRequest", "Java Record", "文档上传请求")
        Component(doc_resp, "DocumentResponse", "Java Record", "文档响应")
        Component(fc_tool_req, "FunctionCallRequest", "Java Record", "Function Call 请求 (functioncall/)")
        Component(fc_tool_resp, "FunctionCallResponse", "Java Record", "Function Call 响应 (functioncall/)")
        Component(fc_tools_list_resp, "ToolsListResponse", "Java Record", "工具列表响应 (functioncall/)")
    }

    ' ============================================================
    ' APPLICATION LAYER
    ' ============================================================
    Container_Boundary(app_layer, "Application Layer") {

        ' Ports (interfaces defined in Application layer)
        Component(ai_chat_port, "AiChatPort", "Interface", "AI 聊天能力抽象")
        Component(chat_sess_repo_port, "ChatSessionRepositoryPort", "Interface", "会话仓储抽象")
        Component(embedding_port, "EmbeddingPort", "Interface", "文本嵌入能力抽象")
        Component(vector_search_port, "VectorSearchPort", "Interface", "向量检索抽象")
        Component(doc_repo_port, "DocumentRepositoryPort", "Interface", "文档仓储抽象")
        Component(tool_reg_port, "ToolRegistryPort", "Interface", "工具注册抽象")

        ' Use Cases
        Component(send_msg_uc, "SendChatMessageUseCase", "UseCase", "发送聊天消息用例")
        Component(upload_doc_uc, "UploadDocumentUseCase", "UseCase", "上传文档、分块、嵌入生成")
        Component(delete_doc_uc, "DeleteDocumentUseCase", "UseCase", "删除文档及向量数据")
        Component(rag_chat_uc, "RagChatUseCase", "UseCase", "RAG 检索增强问答")

        ' Application Services
        Component(chat_app_svc, "ChatApplicationService", "@Service", "聊天应用服务")
        Component(rag_app_svc, "RagApplicationService", "@Service", "RAG 应用服务")
        Component(lang_detect_svc, "LanguageDetectionService", "@Service", "语言检测服务")

        ' Tool Abstraction
        Container_Boundary(tool_abstraction, "Tool Abstraction") {
            Component(tool_def, "ToolDefinition", "Abstract Class", "工具定义抽象")
            Component(tool_invoke, "ToolInvocation", "Abstract Class", "工具调用抽象")
            Component(tool_result, "ToolResult", "Abstract Class", "工具结果抽象")
            Component(tool_provider, "ToolProvider", "Abstract Class", "工具提供者抽象")
            Component(tool_exec, "ToolExecutor", "Abstract Class", "工具执行器抽象")
        }
    }

    ' ============================================================
    ' DOMAIN LAYER (repositories are in application.port — domain.repository/ is empty)
    ' ============================================================
    Container_Boundary(domain_layer, "Domain Layer") {

        ' Models (Aggregates & Entities)
        Component(chat_session, "ChatSession", "Aggregate Root", "聊天会话聚合根，含 ChatSessionStatus")
        Component(chat_message, "ChatMessage", "Entity", "聊天消息实体，含 ChatMessageType")
        Component(document, "Document", "Entity", "文档实体，含 DocumentStatus")
        Component(doc_chunk, "DocumentChunk", "Entity", "文档分块实体")
        Component(source_doc, "SourceDocument", "Value Object", "检索来源文档")

        ' Value Objects
        Component(chat_sess_id, "ChatSessionId", "Java Record", "会话唯一标识")
        Component(msg_id, "MessageId", "Java Record", "消息唯一标识")
        Component(msg_content, "MessageContent", "Java Record", "消息内容")
        Component(doc_id, "DocumentId", "Java Record", "文档唯一标识")

        ' Domain Service
        Component(ai_chat_svc, "AiChatService", "Domain Service", "AI 对话核心服务")

        ' Domain Events
        Component(msg_rcvd_evt, "ChatMessageReceivedEvent", "Java Record", "消息接收事件")
        Component(resp_gen_evt, "ChatResponseGeneratedEvent", "Java Record", "响应生成事件")
        Component(domain_evt, "DomainEvent", "Interface", "领域事件接口")

        ' Domain Exceptions
        Component(ai_svc_exc, "AiServiceException", "Exception", "AI 服务异常")
        Component(sess_not_found_exc, "ChatSessionNotFoundException", "Exception", "会话未找到异常")
        Component(doc_not_found_exc, "DocumentNotFoundException", "Exception", "文档未找到异常")
        Component(rag_svc_exc, "RagServiceException", "Exception", "RAG 服务异常")
    }

    ' ============================================================
    ' INFRASTRUCTURE LAYER
    ' ============================================================
    Container_Boundary(infra_layer, "Infrastructure Layer") {

        ' Configuration Classes
        Container_Boundary(configs, "Configuration Classes") {
            Component(app_cfg, "ApplicationConfig", "@Configuration", "应用总配置")
            Component(mcp_srv_cfg, "McpServerConfig", "@Configuration", "MCP 服务器配置，/mcp 端点")
            Component(tool_reg_cfg, "ToolRegistryConfig", "@Configuration", "工具注册配置")
            Component(pg_cfg, "PostgresConfig", "@Configuration", "PostgreSQL 配置")
            Component(ollama_cfg, "OllamaConfig", "@Configuration", "Ollama 配置")
            Component(rag_props, "RagProperties", "@ConfigurationProperties", "RAG 配置属性")
            Component(monitor_props, "MonitorProperties", "@ConfigurationProperties", "监控配置属性")
            Component(websearch_props, "WebSearchProperties", "@ConfigurationProperties", "Web 搜索配置属性")
            Component(cors_cfg, "WebCorsConfig", "@Configuration", "跨域配置")
        }

        ' AI Adapters
        Container_Boundary(ai_adapters, "AI Adapters") {
            Component(spring_ai_chat_adapter, "SpringAiChatAdapter", "@Component", "AI 聊天端口适配器")
            Component(spring_ai_chat_svc, "SpringAiChatService", "@Component", "Spring AI 服务实现")
            Component(doc_search_tool_adapter, "DocumentSearchTool", "@Component", "文档搜索工具")
        }

        ' Embedding Adapters
        Container_Boundary(emb_adapters, "Embedding Adapters") {
            Component(ollama_emb_adapter, "OllamaEmbeddingAdapter", "@Component", "Ollama Embedding 适配器")
            Component(mock_emb_adapter, "MockEmbeddingAdapter", "@Component", "Mock Embedding 适配器")
        }

        ' Vector Adapters
        Container_Boundary(vector_adapters, "Vector Adapters") {
            Component(pgvector_adapter, "PgVectorAdapter", "@Component", "PostgreSQL/pgvector 向量检索")
        }

        ' Document Adapters
        Container_Boundary(doc_adapters, "Document Adapters") {
            Component(pdf_extractor, "PdfTextExtractor", "@Component", "PDF 文本提取")
        }

        ' Web Search Adapters
        Container_Boundary(web_adapters, "Web Search Adapters") {
            Component(ddg_adapter, "DuckDuckGoWebSearchAdapter", "@Component", "DuckDuckGo Web 搜索适配器")
            Component(websearch_port_impl, "WebSearchPort", "Interface + Impl", "Web 搜索抽象 + 实现")
            Component(websearch_cfg, "WebSearchConfig", "@Configuration", "Web 搜索配置")
            Component(websearch_result, "WebSearchResult", "Java Record", "Web 搜索结果")
        }

        ' Monitor Adapters
        Container_Boundary(monitor_adapters, "Monitor Adapters") {
            Component(osh_sysinfo, "OshiSystemInfoProvider", "@Component", "系统信息提供者")
            Component(sysinfo_port, "SystemInfoProvider", "Interface", "系统信息抽象")
        }

        ' MCP Adapter
        Container_Boundary(mcp_adapters, "MCP Adapter") {
            Component(mcp_adapter, "McpToolCallbackAdapter", "@Component", "MCP 工具回调适配器")
        }

        ' Persistence Adapters
        Container_Boundary(persistence_adapters, "Persistence Adapters") {
            Component(in_mem_sess_repo, "InMemoryChatSessionRepository", "@Repository", "内存会话存储")
            Component(jpa_doc_repo, "JpaDocumentRepository", "@Component", "JPA 文档仓储实现")
            Component(doc_entity, "DocumentEntity", "JPA Entity", "文档 JPA 实体")
            Component(doc_chunk_entity, "DocumentChunkEntity", "JPA Entity", "分块 JPA 实体")
            Component(spring_data_doc_repo, "SpringDataDocumentRepository", "Spring Data JPA", "文档数据访问")
            Component(spring_data_chunk_repo, "SpringDataChunkRepository", "Spring Data JPA", "分块数据访问")
        }

        ' Tool Implementations
        Container_Boundary(tool_impls, "Tool Implementations") {
            Component(in_mem_tool_reg, "InMemoryToolRegistry", "@Component", "内存工具注册表")
            Component(json_schema_builder, "JsonSchemaBuilder", "Utility", "JSON Schema 构建器")
            Component(tool_provider_impl, "ToolProvider", "@Component", "工具提供者实现")
        }

        ' Chat Tools
        Container_Boundary(chat_tools, "Chat Tools") {
            Component(get_chat_hist_tool, "GetChatHistoryTool", "*Tool", "获取聊天历史")
            Component(list_sess_tool, "ListSessionsTool", "*Tool", "列出会话列表")
        }

        ' RAG Tools
        Container_Boundary(rag_tools, "RAG Tools") {
            Component(doc_delete_tool, "DocumentDeleteTool", "*Tool", "删除文档")
            Component(doc_get_tool, "DocumentGetTool", "*Tool", "获取文档")
            Component(doc_list_tool, "DocumentListTool", "*Tool", "列出文档")
            Component(rag_search_tool, "RagSearchTool", "*Tool", "RAG 搜索")
            Component(rag_search_docs_tool, "RagSearchInDocsTool", "*Tool", "文档内搜索")
        }

        ' Web Tools
        Container_Boundary(web_tools, "Web Tools") {
            Component(web_search_tool, "WebSearchTool", "*Tool", "Web 搜索")
        }

        ' Monitor Tools
        Container_Boundary(monitor_tools, "Monitor Tools") {
            Component(get_cpu_tool, "GetCpuTool", "*Tool", "CPU 监控")
            Component(get_disk_tool, "GetDiskTool", "*Tool", "磁盘监控")
            Component(get_jvm_tool, "GetJvmTool", "*Tool", "JVM 监控")
            Component(get_load_tool, "GetLoadTool", "*Tool", "负载监控")
            Component(get_mem_tool, "GetMemoryTool", "*Tool", "内存监控")
        }

        ' Composite Tools
        Container_Boundary(composite_tools, "Composite Tools") {
            Component(supervisor_tool, "SupervisorOverviewTool", "*Tool", "Supervisor 总览")
            Component(k8s_audit_tool, "K8sResourceAuditTool", "*Tool", "K8s 资源审计")
            Component(llmops_pipe_tool, "LlmoopsPipelineTool", "*Tool", "LLMOps 流水线")
            Component(model_eval_tool, "ModelEvaluationTool", "*Tool", "模型评估")
            Component(mon_health_tool, "MonitoringHealthTool", "*Tool", "监控健康检查")
            Component(vector_db_tool, "VectorDbInspectTool", "*Tool", "向量库检查")
            Component(aiop_anomaly_tool, "AiopSAnomalyTool", "*Tool", "AIOps 异常检测")
        }
    }
}

' ============================================================
' EXTERNAL SYSTEMS - 外部系统
' ============================================================
System_Boundary(ext_systems, "External Systems") {
    Component(deepseek_api, "DeepSeek API", "REST API", "LLM 对话 + Text Embedding，HTTPS")
    Component(postgresql_pgvector, "PostgreSQL + pgvector", "PostgreSQL 17", "文档存储 + 向量检索，端口 5432")
    Component(duckduckgo_ext, "DuckDuckGo Search", "HTTPS API", "Web 搜索，HTTPS")
    Component(ollama_ext, "Ollama", "REST API", "本地 Embedding 模型，端口 11434")
}

' ============================================================
' RELATIONSHIPS - 关系定义
' ============================================================

' Interface Layer -> Application Layer
Rel(chat_ctrl, send_msg_uc, "调用")
Rel(chat_ctrl, ex_handler, "异常处理")
Rel(rag_ctrl, rag_app_svc, "调用")
Rel(rag_ctrl, ex_handler, "异常处理")
Rel(agent_ctrl, tool_reg_port, "查询工具列表")
Rel(agent_ctrl, in_mem_tool_reg, "工具调用")
Rel(fc_ctrl, tool_reg_port, "查询工具")

' Application Layer Use Cases
Rel(send_msg_uc, chat_app_svc, "编排")
Rel(chat_app_svc, ai_chat_port, "依赖抽象")
Rel(chat_app_svc, chat_sess_repo_port, "依赖抽象")

Rel(rag_app_svc, upload_doc_uc, "上传文档")
Rel(rag_app_svc, delete_doc_uc, "删除文档")
Rel(rag_app_svc, rag_chat_uc, "RAG 问答")

' Application Layer Ports
Rel(upload_doc_uc, embedding_port, "依赖")
Rel(upload_doc_uc, vector_search_port, "依赖")
Rel(upload_doc_uc, doc_repo_port, "依赖")
Rel(rag_chat_uc, embedding_port, "依赖")
Rel(rag_chat_uc, vector_search_port, "依赖")
Rel(delete_doc_uc, doc_repo_port, "依赖")
Rel(delete_doc_uc, vector_search_port, "依赖")

' Ports -> Infrastructure Adapters
Rel(ai_chat_port, spring_ai_chat_adapter, "实现")
Rel(chat_sess_repo_port, in_mem_sess_repo, "实现")
Rel(embedding_port, ollama_emb_adapter, "实现")
Rel(embedding_port, mock_emb_adapter, "实现")
Rel(vector_search_port, pgvector_adapter, "实现")
Rel(doc_repo_port, jpa_doc_repo, "实现")
Rel(tool_reg_port, in_mem_tool_reg, "实现")

' Infrastructure Adapters -> External Systems
Rel(spring_ai_chat_adapter, spring_ai_chat_svc, "组合")
Rel(spring_ai_chat_svc, deepseek_api, "LLM 调用", "HTTPS")
Rel(ollama_emb_adapter, ollama_ext, "Embedding 生成", "HTTP :11434")
Rel(pgvector_adapter, postgresql_pgvector, "向量存储/检索", "JDBC :5432")
Rel(jpa_doc_repo, postgresql_pgvector, "文档持久化", "JDBC :5432")
Rel(jpa_doc_repo, spring_data_doc_repo, "组合")
Rel(jpa_doc_repo, spring_data_chunk_repo, "组合")
Rel(ddg_adapter, duckduckgo_ext, "Web 搜索", "HTTPS")
Rel(web_search_tool, websearch_port_impl, "Web 搜索抽象")
Rel(websearch_port_impl, ddg_adapter, "实现")
Rel(doc_search_tool_adapter, doc_repo_port, "依赖")

' Domain Layer
Rel(chat_app_svc, chat_session, "操作领域对象")
Rel(chat_session, chat_message, "包含")
Rel(document, doc_chunk, "包含多个")
Rel(doc_chunk, source_doc, "转换为")

' Tool Implementations
Rel(in_mem_tool_reg, mcp_adapter, "MCP 适配")
Rel(in_mem_tool_reg, json_schema_builder, "Schema 构建")
Rel(tool_provider_impl, tool_def, "工具定义")
Rel(tool_provider_impl, tool_invoke, "工具调用")
Rel(tool_provider_impl, chat_tools, "Chat 工具")
Rel(tool_provider_impl, rag_tools, "RAG 工具")
Rel(tool_provider_impl, web_tools, "Web 工具")
Rel(tool_provider_impl, monitor_tools, "监控工具")
Rel(tool_provider_impl, composite_tools, "复合工具")
Rel(monitor_tools, osh_sysinfo, "系统信息")
Rel(rag_tools, doc_repo_port, "文档检索")

SHOW_LEGEND()
@enduml
