@startuml C3-Component-Frontend
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title 组件图 (C3) - Angular 22 Web 前端

System_Boundary(frontend, "Angular 22 Web Application") {

    ' ============================================================
    ' APP LAYER
    ' ============================================================
    Container_Boundary(app_layer, "App Layer") {
        Component(app_root, "AppComponent", "@Component", "根组件")
        Component(main_layout, "MainLayoutComponent", "@Component", "主布局 (header + sidebar + outlet)")
        Component(app_cfg, "app.config.ts", "ApplicationConfig", "providers, interceptors")
        Component(app_routes, "app.routes.ts", "Routes", "路由: /chat /generate /rag /vision")
    }

    ' ============================================================
    ' PAGE COMPONENTS
    ' ============================================================
    Container_Boundary(pages, "Page Components") {
        Component(chat_tab, "ChatTabComponent", "@Component", "对话 (/chat)")
        Component(generate_page, "GeneratePage", "@Component", "生成 (/generate)")
        Container_Boundary(generate_tabs, "Generate Sub-Routes") {
            Component(tts_tab, "TtsPageComponent", "@Component", "TTS Tab (/generate/tts)")
            Component(img_tab, "ImageComponent", "@Component", "图像 Tab (/generate/image)")
        }
        Component(rag_page, "RagPageComponent", "@Component", "RAG 页面 (/rag)")
        Component(vision_page, "VisionPageComponent", "@Component", "图像分析 (/vision: Caption/Detect/OCR)")
        Component(detect_overlay, "DetectionOverlayComponent", "@Component", "检测边界框叠加层")
    }

    ' ============================================================
    ' FEATURE SERVICES
    ' ============================================================
    Container_Boundary(feature_services, "Feature Services") {
        Component(chat_svc, "ChatService", "@Injectable", "聊天 SSE 流式")
        Component(rag_svc, "RagService", "@Injectable", "RAG 文档与问答")
        Component(stream_parser, "StreamParserService", "@Injectable", "SSE 事件解析")
    }

    ' ============================================================
    ' CORE SERVICES
    ' ============================================================
    Container_Boundary(core_services, "Core Services") {
        Component(api_svc, "ApiService", "@Injectable", "通用 REST: chat/rag/image/tts/vision")
        Component(notif_svc, "NotificationService", "@Injectable", "Toast 通知")
        Component(http_err_interceptor, "HttpErrorInterceptor", "Interceptor", "HTTP 错误拦截")
        Component(sidebar_svc, "SidebarService", "@Injectable", "侧边栏状态")
        Component(i18n_svc, "I18nService", "@Injectable", "国际化 (5 语言)")
        Component(theme_svc, "ThemeService", "@Injectable", "主题切换")
        Component(voice_interaction_svc, "VoiceInteractionService", "@Injectable", "录音→ASR 编排")
        Component(voice_transcription_svc, "VoiceTranscriptionService", "@Injectable", "WebSocket ASR 客户端")
        Component(voice_playback_svc, "VoicePlaybackService", "@Injectable", "TTS 朗读与静音")
        Component(wav_encoder, "wav-encoder.util", "Util", "Float32 → WAV 16kHz mono")
    }

    ' ============================================================
    ' SHARED UI
    ' ============================================================
    Container_Boundary(shared_layer, "Shared UI") {
        Component(ui_card, "CardComponent", "@Component", "卡片")
        Component(ui_button, "ButtonComponent", "@Component", "按钮")
        Component(ui_seg_ctrl, "SegmentedControlComponent", "@Component", "分段控制器")
        Component(citation_comp, "CitationComponent", "@Component", "RAG 来源引用")
        Component(toast_comp, "ToastComponent", "@Component", "Toast 通知")
        Component(img_zoom, "ImageZoomModalComponent", "@Component", "图片缩放")
        Component(markdown_svc, "MarkdownService", "@Injectable", "Markdown 渲染")
    }
}

' ============================================================
' EXTERNAL
' ============================================================
System_Boundary(external, "Backend & Browser") {
    Component(backend_api, "AI Platform Backend", "REST/SSE/WebSocket", "Spring Boot :9000")
    Component(browser_apis, "Browser APIs", "Web APIs", "HttpClient, WebSocket, SSE")
}

' ============================================================
' ROUTES
' ============================================================
Rel(app_routes, main_layout, "根布局")
Rel(main_layout, chat_tab, "/chat")
Rel(main_layout, generate_page, "/generate")
Rel(main_layout, rag_page, "/rag")
Rel(main_layout, vision_page, "/vision")
Rel(generate_page, tts_tab, "/generate/tts")
Rel(generate_page, img_tab, "/generate/image")

' ============================================================
' SERVICE RELATIONSHIPS
' ============================================================
Rel(chat_tab, chat_svc, "聊天")
Rel(chat_tab, voice_interaction_svc, "麦克风录音/转写")
Rel(chat_tab, voice_playback_svc, "TTS 朗读/静音")
Rel(voice_interaction_svc, voice_transcription_svc, "WebSocket ASR")
Rel(voice_interaction_svc, wav_encoder, "WAV 编码")
Rel(voice_transcription_svc, backend_api, "ws /ws/audio/transcribe", "WebSocket")
Rel(voice_playback_svc, api_svc, "TTS")
Rel(chat_tab, stream_parser, "SSE 解析")
Rel(rag_page, rag_svc, "RAG")
Rel(tts_tab, api_svc, "TTS API")
Rel(img_tab, api_svc, "图像 API")
Rel(vision_page, api_svc, "视觉 API")
Rel(vision_page, detect_overlay, "检测叠加")

Rel(chat_svc, api_svc, "HTTP/SSE")
Rel(rag_svc, api_svc, "HTTP/SSE")
Rel(api_svc, backend_api, "proxy /api/* → :9000", "HTTP")
Rel(notif_svc, toast_comp, "触发 Toast")
Rel(app_root, theme_svc, "主题")
Rel(app_root, i18n_svc, "国际化")
Rel(app_root, http_err_interceptor, "错误拦截")

SHOW_LEGEND()
@enduml
