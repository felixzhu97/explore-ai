@startuml AI-Test-Wardley-Map
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()
skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 9
skinparam dpi 150

title AI-Test Platform 技术演进地图 (C4 Container)

' ============================================================
' ANCHOR - 用户 (最高可见度)
' ============================================================
Person(user, "用户", "ML 工程师 / 运维工程师 / 数据科学家")

' ============================================================
' GENESIS 阶段 - 创新/定制能力 (左下角，演化早期)
' ============================================================
Container_Boundary(genesis, "Genesis (创新阶段)") {
    Container(multi_agent, "Multi-Agent Orchestration", "Java", "多 Agent 编排与任务路由")
    Container(rag, "RAG + Vector Search", "Java/Spring AI", "文档检索与向量搜索")
    Container(vision_ai, "Vision AI Pipeline", "Java", "图像分析处理流水线")
    Container(tts, "TTS 语音合成", "Java/Spring AI", "文本转语音服务")
    Container(image_gen, "Image Gen 图像生成", "Java/Spring AI", "AI 图像生成")
    Container(aiops, "AIOps 智能分析", "Java", "运维智能分析与告警")
    Container(mcp, "MCP Server/Client", "Java/Spring AI", "Model Context Protocol")
}

' ============================================================
' CUSTOM BUILT 阶段 - 定制开发 (中部，差异化能力)
' ============================================================
Container_Boundary(frontend, "Frontend (Angular 22)") {
    Container(fe_app, "AppComponent", "Angular 22", "根组件")
    Container(fe_infra, "AIInfraPanel", "Angular 22", "AI 基础设施面板")
    Container(fe_rag_chat, "RagChatComponent", "Angular 22", "RAG 对话组件")
    Container(fe_vision, "VisionPanel", "Angular 22", "视觉分析面板")
    Container(fe_agent, "AgentChatComponent", "Angular 22", "Agent 对话 (SSE)")
    Container(fe_ai_service, "AiService", "Angular 22", "AI 能力服务")
    Container(fe_api, "ApiService", "Angular 22", "API 通信服务")
}

Container_Boundary(chat_backend, "Chat Backend (Java 25)") {
    Container(chat_ctrl, "ChatController", "REST API", "HTTP 接口")
    Container(chat_app, "ChatApplicationService", "Java", "应用服务")
    Container(chat_session, "ChatSession", "DDD Aggregate", "会话聚合根")
    Container(chat_adapter, "SpringAiChatAdapter", "Spring AI 2.0", "AI 适配器")
}

Container_Boundary(rag_backend, "RAG Backend (Java 25)") {
    Container(rag_ctrl, "RagController", "REST/SSE API", "HTTP 接口")
    Container(rag_app, "RagApplicationService", "Java", "应用服务")
    Container(rag_emb, "DeepSeekEmbeddingAdapter", "Spring AI", "嵌入模型适配器")
    Container(rag_vec, "PgVectorAdapter", "pgvector", "向量数据库适配器")
    Container(rag_doc_repo, "JpaDocumentRepository", "Spring Data JPA", "文档仓储")
}

Container_Boundary(mcp_backend, "MCP Backend (Java 25)") {
    Container(mcp_ctrl, "McpController", "REST API", "MCP 服务控制")
    Container(mcp_client, "AiMcpClientService", "Java", "MCP 客户端服务")
}

Container_Boundary(domain, "Domain Layer (DDD)") {
    Container(vo, "Value Objects", "Java Record", "SessionId/MessageId/Email")
    Container(domain_evt, "Domain Events", "Java", "领域事件")
    Container(domain_exc, "Domain Exceptions", "Java", "业务异常")
}

' ============================================================
' PRODUCT 阶段 - 商业/开源组件 (右侧，采购能力)
' ============================================================
Container_Boundary(products, "Product (商业/开源)") {
    Container(angular, "Angular 22", "Framework", "前端框架")
    Container(spring_boot, "Spring Boot 3.5", "Framework", "后端框架")
    Container(spring_ai, "Spring AI 2.0", "Library", "AI 集成框架")
    Container(deepseek, "DeepSeek API", "LLM Service", "大语言模型 + Embedding")
    Container(yolo, "YOLO11n", "ML Model", "目标检测模型")
    Container(paddleocr, "PaddleOCR", "ML Model", "OCR 文字识别")
    Container(blip, "BLIP", "ML Model", "图像描述生成")
    Container(dalle, "DALL-E", "API", "图像生成服务")
    Container(edge_tts, "Edge TTS", "API", "微软语音合成")
}

' ============================================================
' COMMODITY 阶段 - 标准化基础设施 (右下角，演化后期)
' ============================================================
Container_Boundary(commodity, "Commodity (标准化基础设施)") {
    Container(nodejs, "Node.js", "Runtime", "前端运行时")
    Container(java, "Java 25", "Runtime", "后端运行时")
    Container(postgres, "PostgreSQL 17 + pgvector", "Database", "关系型 + 向量数据库")
    Container(redis, "Redis", "Cache", "缓存服务")
    Container(k8s, "Kubernetes", "Orchestration", "容器编排")
    Container(docker, "Docker", "Container", "容器化")
    Container(http, "HTTP/WebSocket/SSE", "Protocol", "通信协议")
    Container(prom, "Prometheus/Grafana", "Monitoring", "监控告警")
    Container(otel, "OpenTelemetry", "Observability", "可观测性")
    Container(gradle, "Gradle", "Build Tool", "构建工具")
    Container(gha, "GitHub Actions", "CI/CD", "持续集成部署")
}

' ============================================================
' RELATIONSHIPS - 依赖关系
' ============================================================

' 用户 -> Frontend
Rel(user, fe_infra, "查看监控")
Rel(user, fe_rag_chat, "RAG 对话")
Rel(user, fe_vision, "图像分析")
Rel(user, fe_agent, "Agent 对话")

' Frontend 内部
Rel(fe_app, fe_ai_service, "调用")
Rel(fe_infra, fe_agent, "Agent 入口")
Rel(fe_ai_service, fe_api, "HTTP 请求")

' Frontend -> Backend
Rel(fe_api, chat_ctrl, "聊天请求")
Rel(fe_api, rag_ctrl, "RAG 请求")
Rel(fe_ai_service, rag_emb, "Embedding")
Rel(fe_ai_service, yolo, "目标检测")
Rel(fe_ai_service, dalle, "图像生成")
Rel(fe_ai_service, edge_tts, "语音合成")

' Chat Backend
Rel(chat_ctrl, chat_app, "应用服务")
Rel(chat_app, chat_session, "会话管理")
Rel(chat_app, chat_adapter, "AI 调用")
Rel(chat_adapter, deepseek, "LLM 请求")

' RAG Backend
Rel(rag_ctrl, rag_app, "应用服务")
Rel(rag_app, rag_emb, "嵌入生成")
Rel(rag_app, rag_vec, "向量检索")
Rel(rag_app, rag_doc_repo, "文档存储")
Rel(rag_emb, deepseek, "Embedding")
Rel(rag_vec, postgres, "向量查询")

' MCP Backend
Rel(mcp_ctrl, mcp_client, "客户端服务")
Rel(mcp_client, spring_ai, "AI 集成")

' Domain Layer
Rel(chat_session, vo, "值对象")
Rel(chat_app, domain_evt, "事件发布")
Rel(chat_app, domain_exc, "异常处理")

' Genesis -> Custom Built
Rel(multi_agent, fe_agent, "编排")
Rel(multi_agent, chat_app, "编排")
Rel(rag, fe_rag_chat, "检索")
Rel(rag, rag_app, "检索")
Rel(vision_ai, fe_vision, "分析")
Rel(tts, fe_ai_service, "合成")
Rel(image_gen, fe_ai_service, "生成")
Rel(aiops, fe_infra, "监控")
Rel(mcp, mcp_ctrl, "协议")

' Product -> Commodity
Rel(angular, nodejs, "运行时")
Rel(spring_boot, java, "运行时")
Rel(spring_ai, spring_boot, "集成")
Rel(deepseek, http, "API 调用")
Rel(dalle, http, "API 调用")
Rel(yolo, docker, "容器")
Rel(paddleocr, docker, "容器")
Rel(blip, docker, "容器")
Rel(edge_tts, http, "API 调用")

' Commodity 内部
Rel(java, k8s, "部署")
Rel(gradle, java, "构建")
Rel(postgres, docker, "容器")
Rel(redis, docker, "容器")
Rel(prom, k8s, "监控")
Rel(otel, k8s, "追踪")
Rel(http, k8s, "服务")
Rel(gha, k8s, "部署")

SHOW_LEGEND()
@enduml
