grep -r "import org.springframework" src/domain/ || echo "✅ Domain 无 Spring 依赖"
grep -r "import jakarta.persistence" src/domain/ || echo "✅ Domain 无 JPA 依赖"
grep -r "import javax.persistence" src/domain/ || echo "✅ Domain 无 JPA 依赖"
grep -r "@Entity" src/domain/ || echo "✅ Domain 无实体注解"

# 检查依赖方向
grep -r "import.*application" src/domain/ || echo "✅ Domain 不依赖 Application"
grep -r "import.*infrastructure" src/domain/ || echo "✅ Domain 不依赖 Infrastructure"
grep -r "import.*interface" src/domain/ || echo "✅ Domain 不依赖 Interface"
```
