## Domain 层规范

### 实体 (Entity) - 充血模型

```java
// ✅ 正确: 充血模型，业务逻辑在实体内部
package com.ai.domain.model;

import com.ai.domain.event.OrderPlacedEvent;
import com.ai.domain.exception.OrderException;

import java.math.BigDecimal;
import java.time.Instant;
import java.util.ArrayList;
import java.util.List;
import java.util.UUID;

public class Order extends AggregateRoot {

    private final OrderId id;
    private CustomerId customerId;
    private OrderStatus status;
    private final List<OrderLine> lines;
    private Instant createdAt;

    // 私有构造函数，通过工厂方法创建
    private Order(OrderId id, CustomerId customerId) {
        this.id = Objects.requireNonNull(id);
        this.customerId = Objects.requireNonNull(customerId);
        this.status = OrderStatus.DRAFT;
        this.lines = new ArrayList<>();
        this.createdAt = Instant.now();
    }

    public static Order create(CustomerId customerId) {
        return new Order(new OrderId(UUID.randomUUID()), customerId);
    }

    // 唯一入口: 添加商品行
    public void addLine(Product product, int quantity) {
        validateCanModify();
        if (quantity <= 0) {
            throw OrderException.invalidQuantity(quantity);
        }
        lines.add(new OrderLine(product.getId(), product.getPrice(), quantity));
    }

    // 业务方法: 下单
    public void place() {
        validateCanPlace();
        this.status = OrderStatus.PLACED;
        addDomainEvent(new OrderPlacedEvent(id, customerId, calculateTotal(), Instant.now()));
    }

    // 业务方法: 取消
    public void cancel() {
        if (status != OrderStatus.DRAFT && status != OrderStatus.PLACED) {
            throw OrderException.cannotCancel(status);
        }
        this.status = OrderStatus.CANCELLED;
    }

    // 计算逻辑
    public Money calculateTotal() {
        return lines.stream()
                .map(OrderLine::subtotal)
                .reduce(Money.ZERO, Money::add);
    }

    // 验证逻辑
    private void validateCanPlace() {
        if (status != OrderStatus.DRAFT) {
            throw OrderException.invalidStatusForPlacement(status);
        }
        if (lines.isEmpty()) {
            throw OrderException.empty();
        }
    }

    private void validateCanModify() {
        if (status != OrderStatus.DRAFT) {
            throw OrderException.cannotModifyAfterPlacement();
        }
    }

    // Getters (无 Setters)
    public OrderId getId() { return id; }
    public OrderStatus getStatus() { return status; }
    public Money getTotalAmount() { return calculateTotal(); }
    public List<OrderLine> getLines() { return List.copyOf(lines); }

    // 状态枚举
    public enum OrderStatus { DRAFT, PLACED, PAID, SHIPPED, CANCELLED }
}
```

### 值对象 (Value Object)

```java
// ✅ 正确: 不可变值对象，使用 Java Record
package com.ai.domain.value;

import com.ai.domain.exception.DomainException;

public record Money(
    BigDecimal amount,
    Currency currency
) {
    public Money {
        Objects.requireNonNull(amount, "Amount cannot be null");
        Objects.requireNonNull(currency, "Currency cannot be null");
        if (amount.compareTo(BigDecimal.ZERO) < 0) {
            throw DomainException.negativeAmount();
        }
    }

    // 工厂方法
    public static Money of(double value) {
        return new Money(BigDecimal.valueOf(value), Currency.DEFAULT);
    }

    public static Money zero() {
        return new Money(BigDecimal.ZERO, Currency.DEFAULT);
    }

    // 业务方法
    public Money add(Money other) {
        validateCurrency(other.currency());
        return new Money(this.amount.add(other.amount), this.currency);
    }

    public Money multiply(int factor) {
        return new Money(this.amount.multiply(BigDecimal.valueOf(factor)), this.currency);
    }

    public boolean isGreaterThanOrEqual(Money other) {
        validateCurrency(other.currency);
        return this.amount.compareTo(other.amount) >= 0;
    }

    private void validateCurrency(Currency other) {
        if (!this.currency.equals(other)) {
            throw DomainException.currencyMismatch();
        }
    }

    // 内部枚举
    public enum Currency {
        USD, CNY, EUR;

        public static final Currency DEFAULT = USD;
    }
}
```

### 聚合根 (Aggregate Root)

```java
// ✅ 正确: 聚合根管理内部一致性
package com.ai.domain.model;

public abstract class AggregateRoot {
    private final List<DomainEvent> domainEvents = new ArrayList<>();

    protected void addDomainEvent(DomainEvent event) {
        domainEvents.add(event);
    }

    public List<DomainEvent> pullDomainEvents() {
        List<DomainEvent> events = new ArrayList<>(domainEvents);
        domainEvents.clear();
        return events;
    }

    protected abstract void validate();
}
```

