{
  "name": "explore-ai",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "lint": "ng lint",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.spec.json --noEmit",
    "build": "node scripts/inject-launchdarkly-env.mjs && node scripts/inject-datadog-env.mjs && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:visual": "playwright test e2e/*.visual.spec.ts",
    "e2e:visual:update": "playwright test e2e/*.visual.spec.ts --update-snapshots",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "clean": "rm -rf dist .angular node_modules/.cache",
    "prepare": "husky",
    "vision:verify": "chmod +x scripts/verify-vision.sh && ./scripts/verify-vision.sh all",
    "vision:fixtures": "chmod +x scripts/generate-vision-fixtures.sh && ./scripts/generate-vision-fixtures.sh",
    "vision:models": "chmod +x scripts/download-vision-models.sh && ./scripts/download-vision-models.sh",
    "server:test": "./gradlew test",
    "server:test:watch": "./gradlew test --continuous",
    "server:test:coverage": "./gradlew test jacocoTestReport"
  },
  "dependencies": {
    "@a2ui/angular": "^0.10.3",
    "@a2ui/web_core": "^0.10.4",
    "@analogjs/vite-plugin-angular": "^2.6.0",
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.4",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@ant-design/icons-angular": "^21.0.0",
    "@datadog/browser-rum": "^7.5.0",
    "@floating-ui/dom": "^1.7.6",
    "@launchdarkly/js-client-sdk": "^4.9.1",
    "@ng-icons/core": "^34.0.0",
    "@ng-icons/lucide": "^34.0.0",
    "@tailwindcss/postcss": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.9",
    "echarts": "^6.1.0",
    "marked": "^18.0.5",
    "nanoid": "^5.1.11",
    "ng-zorro-antd": "^21.3.1",
    "ng-zorro-x": "^0.3.0",
    "ngx-echarts": "^22.0.0",
    "ngx-sonner": "^3.1.0",
    "postcss": "^8.5.15",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@analogjs/vitest-angular": "^2.6.0",
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.20.0",
    "@vitest/browser": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "angular-eslint": "22.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-tailwindcss": "^4.0.4",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^17.0.8",
    "sass-embedded": "^1.100.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.0",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.1.8",
    "zard-cli": "1.0.0-beta.70"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "engines": {
    "node": "24.x"
  }
}