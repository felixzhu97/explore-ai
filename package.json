{
  "name": "ai-explore",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm -r run clean",
    "prepare": "husky",
    "web:dev": "cd apps/web && npm start",
    "server:dev": "cd apps/server && export $(grep -v '^#' .env | xargs) && ./gradlew bootRun",
    "dev:all": "npm run server:dev && npm run web:dev",
    "docker:up": "cd apps/server && docker compose up -d",
    "docker:down": "cd apps/server && docker compose down",
    "server:test": "cd apps/server && ./gradlew test",
    "server:test:watch": "cd apps/server && ./gradlew test --continuous",
    "server:test:coverage": "cd apps/server && ./gradlew test jacocoTestReport"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/browser": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.1"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  }
}
