{
  "name": "explore-ai",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "lint": "ng lint",
    "typecheck": "tsc --build --noEmit",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "ng e2e",
    "e2e:headed": "ng e2e --headed",
    "e2e:ui": "ng e2e --ui",
    "clean": "pnpm -r run clean",
    "prepare": "husky",
    "server:start": "([ -f .env ] && export $(grep -v '^#' .env | xargs) || true) && ./gradlew bootRun",
    "server:test": "./gradlew test",
    "server:test:watch": "./gradlew test --continuous",
    "server:test:coverage": "./gradlew test jacocoTestReport"
  },
  "dependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.0",
    "@angular/animations": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@ant-design/icons-angular": "^21.0.0",
    "@tailwindcss/postcss": "^4.3.1",
    "dompurify": "^3.4.9",
    "marked": "^18.0.5",
    "nanoid": "^5.1.11",
    "ng-zorro-antd": "^21.3.1",
    "ng-zorro-x": "^0.3.0",
    "postcss": "^8.5.15",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@analogjs/vitest-angular": "^2.6.0",
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.20.0",
    "@vitest/browser": "^1.6.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^1.6.1",
    "angular-eslint": "22.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-tailwindcss": "^4.0.4",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^17.0.8",
    "sass-embedded": "^1.100.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.0",
    "typescript-eslint": "8.60.1",
    "vitest": "^1.6.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "engines": {
    "node": "24.x"
  }
}