# Text-to-Speech Service Configuration

# Provider selection: azure, google, elevenlabs, coqui, edge
TTS_PROVIDER=edge

# Azure Cognitive Services TTS
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# Google Cloud TTS
# Set GOOGLE_APPLICATION_CREDENTIALS environment variable to your service account JSON path
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Coqui TTS (local)
COQUI_MODEL_PATH=models/tts_models/en/models--multilingual--multi_subject--libritts.pth

# Edge TTS (Microsoft Neural Voices - no API key required)
# Just set TTS_PROVIDER=edge and it works out of the box

# Default voice settings
DEFAULT_VOICE=zh-CN-XiaoxiaoNeural
DEFAULT_LANGUAGE=zh-CN
DEFAULT_SPEED=1.0
DEFAULT_PITCH=0

# Server settings
TTS_HOST=0.0.0.0
TTS_PORT=8004

# Cache settings
ENABLE_CACHE=true
CACHE_TTL=3600
