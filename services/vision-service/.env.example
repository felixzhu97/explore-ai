# AI Vision Service Configuration

# Vision Model settings
YOLO_MODEL=yolo11n.pt
BLIP_MODEL=Salesforce/blip-image-captioning-large
OCR_LANG=ch

# HuggingFace mirror (for China)
HF_ENDPOINT=https://hf-mirror.com

# Service settings
MAX_IMAGE_SIZE=10485760
DEVICE=cuda
MODEL_CACHE_DIR=./models
MAX_CONCURRENT_REQUESTS=4

# Image Generation Settings (Stable Diffusion)
SDXL_MODEL=stabilityai/stable-diffusion-xl-base-1.0
DIFFUSION_MODEL=stabilityai/stable-diffusion-3-medium
SD_VAE_MODEL=stabilityai/sdxl-vae
USE_ATTENTION_SLICING=true
USE_SDPA=true
ENABLE_CPU_OFFLOAD=false
ENABLE_VAE_SPLITTING=true

# Video Generation Settings (Optional - for future use)
VIDEO_PROVIDER=mock
REPLICATE_API_TOKEN=your_replicate_token_here
KLING_API_KEY=your_kling_api_key
KLING_API_SECRET=your_kling_api_secret
VIDEO_MAX_DURATION=10
VIDEO_DEFAULT_FPS=24
VIDEO_DEFAULT_RESOLUTION=720p
VIDEO_WEBHOOK_URL=
