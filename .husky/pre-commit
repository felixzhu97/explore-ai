#!/usr/bin/env bash
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Type check for server
echo "📦 Type checking apps/server..."
pnpm --filter @ai-test/server typecheck
if [ $? -ne 0 ]; then
  echo "❌ Type check failed for apps/server"
  exit 1
fi

# Type check for utils
echo "📦 Type checking packages/utils..."
pnpm --filter @ai-test/utils typecheck
if [ $? -ne 0 ]; then
  echo "❌ Type check failed for packages/utils"
  exit 1
fi

# Run tests for packages
echo "🧪 Running tests for packages..."
pnpm test --silent
if [ $? -ne 0 ]; then
  echo "❌ Package tests failed"
  exit 1
fi

# Run Angular tests (Vitest)
echo "🧪 Running Angular tests (Vitest)..."
cd apps/web-angular && npx vitest run --silent 2>&1
if [ $? -ne 0 ]; then
  echo "❌ Angular tests failed"
  exit 1
fi
cd ../..

# Run Java tests (JUnit 5)
echo "🧪 Running Java tests (JUnit 5)..."
cd apps/server-java && ./gradlew test --no-daemon -q 2>&1
if [ $? -ne 0 ]; then
  echo "❌ Java tests failed"
  exit 1
fi
cd ..

echo "✅ All pre-commit checks passed!"
