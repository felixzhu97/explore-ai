#!/usr/bin/env sh

set -e

echo "🔍 Running pre-push checks..."

ROOT_DIR="$(git rev-parse --show-toplevel)"

# Angular tests (Vitest)
echo "🧪 Running Angular tests (Vitest)..."
(cd "$ROOT_DIR/apps/web" && pnpm exec vitest run)

# Java tests with JaCoCo coverage verification
echo "🧪 Running Java tests with coverage (JUnit 5 + JaCoCo)..."
chmod +x "$ROOT_DIR/apps/server/gradlew"
(cd "$ROOT_DIR/apps/server" && ./gradlew jacocoTestCoverageVerification --no-daemon)

echo "✅ All pre-push checks passed!"
