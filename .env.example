# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

# DeepSeek API Configuration (for chat, still uses DeepSeek)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Image generation (default: free local Ollama)
# Run: ollama pull x/flux2-klein
IMAGE_PROVIDER=ollama
IMAGE_MODEL=x/flux2-klein
IMAGE_API_KEY=ollama
IMAGE_BASE_URL=http://localhost:11434/v1

# Optional OpenAI DALL-E (set provider=openai)
# OPENAI_API_KEY=your-openai-api-key
# IMAGE_PROVIDER=openai
# IMAGE_MODEL=dall-e-3
# IMAGE_API_KEY=${OPENAI_API_KEY}
# IMAGE_BASE_URL=https://api.openai.com/v1

# Text-to-speech (OpenAI)
# TTS_ENABLED=true
# TTS_MODEL=gpt-4o-mini-tts
# TTS_VOICE=alloy
# TTS_API_KEY=${OPENAI_API_KEY}
# TTS_BASE_URL=https://api.openai.com/v1

# Optional Anthropic provider
ANTHROPIC_API_KEY=

# Enable local Ollama chat provider (default: false)
OLLAMA_VISION_ENABLED=true
OLLAMA_VISION_MODEL=qwen3.5:35b

# Enable SimpleLoggerAdvisor for AI request/response logging in non-prod
AI_LOGGING_ADVISOR_ENABLED=true

# LaunchDarkly feature flags (optional)
LAUNCHDARKLY_ENABLED=true
LAUNCHDARKLY_SDK_KEY=
LAUNCHDARKLY_CLIENT_SIDE_ID=

# Datadog RUM (optional; create your own app at https://us5.datadoghq.com/rum/list)
# Vercel build: set DD_APPLICATION_ID + DD_CLIENT_TOKEN (injected by scripts/inject-datadog-env.mjs)
# Railway APM: DD_API_KEY + DD_SITE
DD_API_KEY=
DD_SITE=us5.datadoghq.com
DD_APPLICATION_ID=
DD_CLIENT_TOKEN=

# H2 Database Configuration (optional)
H2_URL=jdbc:h2:file:./data/explore-ai;AUTO_SERVER=TRUE
H2_USER=sa
H2_PASSWORD=

# Serper API Key
SERPER_API_KEY=your-serper-api-key