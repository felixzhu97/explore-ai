# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# DeepSeek API Configuration (for chat, still uses DeepSeek)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional Anthropic provider
ANTHROPIC_API_KEY=

# Enable local Ollama chat provider (default: false)
OLLAMA_VISION_ENABLED=true
OLLAMA_VISION_MODEL=qwen3.5:35b

# Enable SimpleLoggerAdvisor for AI request/response logging in non-prod
AI_LOGGING_ADVISOR_ENABLED=true

# H2 Database Configuration (optional)
H2_URL=jdbc:h2:file:./data/explore-ai;AUTO_SERVER=TRUE
H2_USER=sa
H2_PASSWORD=

# Serper API Key
SERPER_API_KEY=your-serper-api-key